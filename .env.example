# MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/inventario_ventas?retryWrites=true&w=majority&appName=Cluster0

# API
API_PORT=4000

# Zona horaria local en horas (UTC offset). Bolivia = -4, Argentina/Chile = -3, México = -6
# Afecta el corte del día en reportes de caja, ventas de hoy, y tendencias.
TZ_OFFSET_HOURS=-4

# En Vercel configura al menos MONGODB_URI y TZ_OFFSET_HOURS en Project Settings > Environment Variables.
