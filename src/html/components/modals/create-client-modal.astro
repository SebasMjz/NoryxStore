---

---

<div
  class="modal fade"
  id="createClientModal"
  tabindex="-1"
  aria-labelledby="createClientModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="createClientModalLabel">Nuevo cliente</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="createClientForm">
          <div class="mb-3">
            <label for="clientNombre" class="form-label">Nombre</label>
            <input type="text" class="form-control" id="clientNombre" name="nombre" required />
          </div>
          <div class="mb-3">
            <label for="clientCelular" class="form-label">Celular</label>
            <input type="text" class="form-control" id="clientCelular" name="celular" />
          </div>
          <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button
            >
            <button type="submit" class="btn btn-primary">Crear</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('createClientForm')
    if (!(form instanceof HTMLFormElement)) return

    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const formData = new FormData(form)
      const payload = {
        nombre: String(formData.get('nombre') || ''),
        celular: String(formData.get('celular') || '')
      }

      const apiBase =
        window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
          ? 'http://localhost:4000'
          : ''

      const clientId = form.dataset.editId
      const url = clientId ? `${apiBase}/api/clients/${clientId}` : `${apiBase}/api/clients`
      const method = clientId ? 'PUT' : 'POST'

      try {
        const authUser = window.__authUser || {}
        const response = await fetch(url, {
          method: method,
          headers: {
            'Content-Type': 'application/json',
            'x-user-id': authUser.id || '',
            'x-user-name': authUser.username || ''
          },
          body: JSON.stringify(payload)
        })

        if (!response.ok) throw new Error('Error al crear el cliente')

        // Close modal and reset form
        const modalEl = document.getElementById('createClientModal')
        const bootstrapApi = window['bootstrap']
        if (bootstrapApi && modalEl) {
          const modal = bootstrapApi.Modal.getInstance(modalEl)
          if (modal) modal.hide()
        }
        form.reset()

        // Reload the table using loadClients globally
        if (typeof window['loadClients'] === 'function') {
          window['loadClients']()
        } else {
          window.location.reload()
        }
      } catch (error) {
        alert(error.message)
      }
    })

    const modalEl = document.getElementById('createClientModal')
    if (modalEl) {
      modalEl.addEventListener('hidden.bs.modal', () => {
        form.reset()
        delete form.dataset.editId
        const titleEl = modalEl.querySelector('.modal-title')
        if (titleEl) titleEl.textContent = 'Nuevo cliente'

        const btnSubmit = form.querySelector('button[type="submit"]')
        if (btnSubmit) btnSubmit.textContent = 'Crear'
      })
    }
  })
</script>
