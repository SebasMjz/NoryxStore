---

---

<style is:global>
  #moveProductoDropdown {
    background: var(--bs-body-bg);
    border-color: var(--bs-border-color) !important;
  }
  #moveProductoDropdown .list-group-item {
    background: transparent;
    border-color: var(--bs-border-color);
    color: var(--bs-body-color);
  }
  #moveProductoDropdown .list-group-item:hover,
  #moveProductoDropdown .list-group-item:focus {
    background: var(--bs-tertiary-bg);
    color: var(--bs-emphasis-color);
  }
  #moveLinesTable .form-control-sm {
    min-width: 4.5rem;
  }
  .move-special-panel {
    border: 1px solid rgba(111, 66, 193, 0.14);
    background: linear-gradient(180deg, rgba(111, 66, 193, 0.05), rgba(111, 66, 193, 0.02));
    border-radius: 1rem;
    padding: 0.95rem;
  }
  .move-consignacion-banner {
    border: 1px dashed rgba(111, 66, 193, 0.28);
    background: rgba(111, 66, 193, 0.08);
    color: var(--bs-body-color);
    border-radius: 0.85rem;
    padding: 0.75rem 0.9rem;
  }
</style>

<div
  class="modal fade"
  id="createMovementModal"
  tabindex="-1"
  aria-labelledby="createMovementModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="createMovementModalLabel">Nuevo movimiento</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"
        ></button>
      </div>
      <div class="modal-body">
        <form id="createMovementForm">
          <!-- Tipo + Motivo -->
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Tipo <span class="text-danger">*</span></label>
              <div class="d-flex gap-2">
                <div class="form-check form-check-inline flex-grow-1 m-0">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="tipo_movimiento"
                    id="tipoEntrada"
                    value="entrada"
                    checked
                  />
                  <label class="form-check-label d-flex align-items-center gap-1" for="tipoEntrada">
                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                      <i class="ri-arrow-down-circle-line me-1"></i>Entrada
                    </span>
                  </label>
                </div>
                <div class="form-check form-check-inline flex-grow-1 m-0">
                  <input
                    class="form-check-input"
                    type="radio"
                    name="tipo_movimiento"
                    id="tipoSalida"
                    value="salida"
                  />
                  <label class="form-check-label d-flex align-items-center gap-1" for="tipoSalida">
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                      <i class="ri-arrow-up-circle-line me-1"></i>Salida
                    </span>
                  </label>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Motivo <span class="text-danger">*</span></label
              >
              <div id="motivoEntradaGroup">
                <div class="d-flex gap-2 flex-wrap">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo"
                      id="motivoCompra"
                      value="compra"
                      checked
                    />
                    <label class="form-check-label small" for="motivoCompra">Compra</label>
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo"
                      id="motivoReposicion"
                      value="reposicion"
                    />
                    <label class="form-check-label small" for="motivoReposicion">Reposición</label>
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo"
                      id="motivoConsignacionDev"
                      value="consignacion_devolucion"
                    />
                    <label class="form-check-label small" for="motivoConsignacionDev"
                      >Devolución consignación</label
                    >
                  </div>
                </div>
              </div>
              <div id="motivoSalidaGroup" style="display:none;">
                <div class="d-flex gap-2 flex-wrap">
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo_salida"
                      id="motivoVenta"
                      value="venta"
                      checked
                    />
                    <label class="form-check-label small" for="motivoVenta">Venta</label>
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo_salida"
                      id="motivoAjuste"
                      value="ajuste_manual"
                    />
                    <label class="form-check-label small" for="motivoAjuste">Ajuste manual</label>
                  </div>
                  <div class="form-check">
                    <input
                      class="form-check-input"
                      type="radio"
                      name="motivo_salida"
                      id="motivoConsignacionEnvio"
                      value="consignacion_envio"
                    />
                    <label class="form-check-label small" for="motivoConsignacionEnvio"
                      >Consignación</label
                    >
                  </div>
                </div>
              </div>
              <input type="hidden" id="moveMotivo" name="motivo" value="compra" />
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-lg-5 d-none" id="moveClienteWrap">
              <div class="move-special-panel h-100">
                <label class="form-label fw-semibold mb-2"
                  >Cliente <span class="text-danger">*</span></label
                >
                <select id="moveCliente" class="form-select">
                  <option value="">Selecciona un cliente...</option>
                </select>
                <div class="form-text mt-2">Las salidas deben quedar asociadas a un cliente.</div>
              </div>
            </div>

            <div class="col-lg-7 d-none" id="moveConsignacionWrap">
              <div class="move-special-panel h-100">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-2 flex-wrap">
                  <div>
                    <div class="fw-semibold">Consignación origen</div>
                    <div class="small text-muted">
                      Selecciona una salida previa para registrar su devolución o liquidación.
                    </div>
                  </div>
                  <span
                    class="badge rounded-pill text-bg-primary-subtle text-primary border border-primary-subtle"
                    >Consignación</span
                  >
                </div>
                <div class="input-group">
                  <select id="moveConsignacionOrigen" class="form-select">
                    <option value="">Selecciona una consignación...</option>
                  </select>
                  <button
                    type="button"
                    class="btn btn-outline-primary"
                    id="moveLoadConsignacionBtn"
                  >
                    Cargar productos
                  </button>
                </div>
                <div id="moveConsignacionBanner" class="move-consignacion-banner mt-2 small d-none">
                </div>
              </div>
            </div>
          </div>

          <div id="moveEditNotice" class="alert alert-info py-2 small d-none mb-3" role="status">
          </div>

          <!-- Agregar productos al listado -->
          <div id="moveDraftSection" class="card border mb-3">
            <div class="card-body py-3">
              <div class="mb-2">
                <label class="form-label small fw-semibold mb-1">Buscar producto</label>
                <div class="position-relative" id="moveProductoWrapper">
                  <div class="input-group input-group-sm">
                    <span class="input-group-text text-muted"><i class="ri-search-line"></i></span>
                    <input
                      type="text"
                      class="form-control"
                      id="moveProductoSearch"
                      placeholder="Nombre o código..."
                      autocomplete="off"
                      aria-label="Buscar producto"
                    />
                    <button
                      type="button"
                      class="btn btn-outline-secondary"
                      id="moveProductoClear"
                      style="display:none;"
                      title="Limpiar"
                    >
                      <i class="ri-close-line"></i>
                    </button>
                  </div>
                  <div
                    id="moveProductoDropdown"
                    class="list-group position-absolute w-100 border rounded overflow-auto"
                    style="z-index:1070;max-height:180px;display:none;top:calc(100% + 2px);left:0;
                           box-shadow:0 6px 20px rgba(0,0,0,.18);"
                  >
                  </div>
                  <input type="hidden" id="moveProducto" />
                </div>
              </div>

              <div class="row g-2 align-items-end">
                <div class="col-6 col-md-2">
                  <label class="form-label small mb-0" for="moveDraftCantidad">Cantidad</label>
                  <input
                    type="number"
                    class="form-control form-control-sm"
                    id="moveDraftCantidad"
                    min="1"
                    value="1"
                  />
                </div>
                <div class="col-6 col-md-3" id="moveDraftPrecioCompraCol">
                  <label
                    class="form-label small mb-0"
                    for="moveDraftPrecioCompra"
                    id="moveDraftPrecioCompraLabel">P. compra</label
                  >
                  <div class="input-group input-group-sm">
                    <span class="input-group-text">$</span>
                    <input
                      type="number"
                      class="form-control"
                      id="moveDraftPrecioCompra"
                      min="0"
                      step="0.01"
                      placeholder="0"
                    />
                  </div>
                </div>
                <div class="col-6 col-md-3" id="moveDraftPrecioVentaCol">
                  <label
                    class="form-label small mb-0"
                    for="moveDraftPrecioVenta"
                    id="moveDraftPrecioVentaLabel">P. venta</label
                  >
                  <div class="input-group input-group-sm">
                    <span class="input-group-text">$</span>
                    <input
                      type="number"
                      class="form-control"
                      id="moveDraftPrecioVenta"
                      min="0"
                      step="0.01"
                      placeholder="0"
                    />
                  </div>
                </div>
                <div class="col-12 col-md-4">
                  <button type="button" class="btn btn-primary btn-sm w-100" id="moveAddLineBtn">
                    <i class="ri-list-check-2 me-1"></i>Agregar a la lista
                  </button>
                </div>
              </div>
              <p class="form-text text-muted small mb-0 mt-2" id="moveDraftHelpEntrada">
                En <strong>entrada</strong>, el precio de venta queda como el del producto (última
                mercadería registrada).
              </p>
              <p class="form-text text-muted small mb-0 mt-2 d-none" id="moveDraftHelpSalida">
                En <strong>salida</strong> solo indicás cantidad por producto.
              </p>
            </div>
          </div>

          <!-- Lista de líneas -->
          <div class="mb-3">
            <label class="form-label fw-semibold"
              >Productos en este movimiento <span class="text-danger">*</span></label
            >
            <div class="table-responsive border rounded">
              <table class="table table-sm table-hover mb-0" id="moveLinesTable">
                <thead class="table-light">
                  <tr>
                    <th>Producto</th>
                    <th class="text-center" style="width:90px;">Cant.</th>
                    <th class="text-end d-none move-col-precio-compra" style="width:100px;"
                      >P. compra</th
                    >
                    <th class="text-end d-none move-col-precio-venta" style="width:100px;"
                      >P. venta</th
                    >
                    <th style="width:44px;"></th>
                  </tr>
                </thead>
                <tbody id="moveLinesBody">
                  <tr id="moveLinesEmpty">
                    <td colspan="5" class="text-center text-muted small py-4">
                      <i class="ri-inbox-line d-block mb-1 fs-4 opacity-50"></i>
                      Agregá uno o más productos con el buscador de arriba.
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <input type="hidden" id="moveUsuario" name="usuario_id" />

          <div class="mb-3">
            <label for="moveObservacion" class="form-label fw-semibold"
              >Observación <span class="text-muted fw-normal small">(opcional)</span></label
            >
            <textarea
              class="form-control"
              id="moveObservacion"
              name="observacion"
              rows="2"
              placeholder="Detalles del movimiento..."></textarea>
          </div>

          <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button
            >
            <button type="submit" class="btn btn-primary" id="moveSubmitBtn">
              <i class="ri-check-line me-1"></i>Registrar movimiento
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  declare global {
    interface Window {
      __authUser: { id?: string; nombre?: string; [k: string]: any } | null
      moveProductoPicker:
        | { select: (p: any) => void; clear: () => void; getAll: () => any[] }
        | undefined
      movementModalLoadEdit: ((m: any) => void) | undefined
      movementModalLoadTransactionEdit: ((lines: any[], tid: string) => void) | undefined
    }
  }
  declare const bootstrap: { Modal: any }

  type MoveLine = {
    movementLineId?: string
    producto_id: string
    nombre: string
    codigo: string
    cantidad: number
    precio_compra: number | null
    precio_venta: number | null
  }

  document.addEventListener('DOMContentLoaded', () => {
    const apiBase =
      window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
        ? 'http://localhost:4000'
        : ''

    const authUser = window.__authUser
    const usuarioInput = document.getElementById('moveUsuario') as HTMLInputElement
    if (authUser && usuarioInput) usuarioInput.value = authUser.id || ''

    const tipoEntradaRadio = document.getElementById('tipoEntrada') as HTMLInputElement
    const tipoSalidaRadio = document.getElementById('tipoSalida') as HTMLInputElement
    const motivoEntradaGrp = document.getElementById('motivoEntradaGroup') as HTMLElement
    const motivoSalidaGrp = document.getElementById('motivoSalidaGroup') as HTMLElement
    const motivoHidden = document.getElementById('moveMotivo') as HTMLInputElement
    const draftSection = document.getElementById('moveDraftSection') as HTMLElement
    const editNotice = document.getElementById('moveEditNotice') as HTMLElement
    const helpEntrada = document.getElementById('moveDraftHelpEntrada') as HTMLElement
    const helpSalida = document.getElementById('moveDraftHelpSalida') as HTMLElement
    const precioCompraCol = document.getElementById('moveDraftPrecioCompraCol') as HTMLElement
    const precioVentaCol = document.getElementById('moveDraftPrecioVentaCol') as HTMLElement
    const linesBody = document.getElementById('moveLinesBody') as HTMLElement
    const linesEmpty = document.getElementById('moveLinesEmpty') as HTMLElement
    const form = document.getElementById('createMovementForm') as HTMLFormElement

    const searchInput = document.getElementById('moveProductoSearch') as HTMLInputElement
    const clearBtn = document.getElementById('moveProductoClear') as HTMLButtonElement
    const dropdown = document.getElementById('moveProductoDropdown') as HTMLElement
    const prodHidden = document.getElementById('moveProducto') as HTMLInputElement
    const draftCantidad = document.getElementById('moveDraftCantidad') as HTMLInputElement
    const draftPrecioCompra = document.getElementById('moveDraftPrecioCompra') as HTMLInputElement
    const draftPrecioVenta = document.getElementById('moveDraftPrecioVenta') as HTMLInputElement
    const addLineBtn = document.getElementById('moveAddLineBtn') as HTMLButtonElement
    const clienteWrap = document.getElementById('moveClienteWrap') as HTMLElement
    const clienteSelect = document.getElementById('moveCliente') as HTMLSelectElement
    const consignacionWrap = document.getElementById('moveConsignacionWrap') as HTMLElement
    const consignacionSelect = document.getElementById(
      'moveConsignacionOrigen'
    ) as HTMLSelectElement
    const loadConsignacionBtn = document.getElementById(
      'moveLoadConsignacionBtn'
    ) as HTMLButtonElement
    const consignacionBanner = document.getElementById('moveConsignacionBanner') as HTMLElement
    const draftPrecioCompraLabel = document.getElementById(
      'moveDraftPrecioCompraLabel'
    ) as HTMLElement
    const draftPrecioVentaLabel = document.getElementById(
      'moveDraftPrecioVentaLabel'
    ) as HTMLElement
    const consignacionDevRadio = document.getElementById(
      'motivoConsignacionDev'
    ) as HTMLInputElement

    let allProducts: any[] = []
    let allClients: any[] = []
    let consignaciones: any[] = []
    let consignacionDevBlocked = false
    let productosMap: Record<
      string,
      { precio_compra: number | null; precio_venta: number | null }
    > = {}
    let selectedProduct: any = null
    let lines: MoveLine[] = []

    function esc(s: string) {
      return String(s ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
    }

    function getTipoActual() {
      return tipoSalidaRadio?.checked ? 'salida' : 'entrada'
    }

    function isConsignacionDevMode() {
      return getTipoActual() === 'entrada' && motivoHidden.value === 'consignacion_devolucion'
    }

    function setConsignacionDevState(hasConsignaciones: boolean, notice = '') {
      consignacionDevBlocked = !hasConsignaciones
      if (consignacionDevRadio) consignacionDevRadio.disabled = !hasConsignaciones
      if (consignacionBanner) {
        consignacionBanner.textContent = notice
        consignacionBanner.classList.toggle('d-none', !notice)
      }
    }

    function updateConsignacionAvailabilityUi() {
      const blocked = isConsignacionDevMode() && consignacionDevBlocked
      if (loadConsignacionBtn) loadConsignacionBtn.disabled = blocked || !consignaciones.length
      if (consignacionSelect) consignacionSelect.disabled = blocked || !consignaciones.length
      const enableDraft = !blocked
      searchInput.disabled = !enableDraft
      draftCantidad.disabled = !enableDraft
      addLineBtn.disabled = !enableDraft
      draftSection.classList.toggle('d-none', blocked)
    }

    function updateMotivoHidden() {
      const tipo = getTipoActual()
      if (tipo === 'entrada') {
        const checked = motivoEntradaGrp?.querySelector(
          'input[name="motivo"]:checked'
        ) as HTMLInputElement
        motivoHidden.value = checked?.value || 'compra'
      } else {
        const checked = motivoSalidaGrp?.querySelector(
          'input[name="motivo_salida"]:checked'
        ) as HTMLInputElement
        motivoHidden.value = checked?.value || 'venta'
      }
    }

    function syncTipo() {
      const tipo = getTipoActual()
      const isEntrada = tipo === 'entrada'
      const isConsignacionDev = isEntrada && motivoHidden.value === 'consignacion_devolucion'
      motivoEntradaGrp.style.display = isEntrada ? '' : 'none'
      motivoSalidaGrp.style.display = isEntrada ? 'none' : ''
      precioCompraCol.classList.toggle('d-none', isConsignacionDev)
      precioVentaCol.classList.remove('d-none')
      draftPrecioCompraLabel.textContent = 'P. compra'
      draftPrecioVentaLabel.textContent = isConsignacionDev ? 'Ingreso unitario' : 'P. venta'
      helpEntrada.classList.toggle('d-none', !isEntrada)
      helpSalida.classList.toggle('d-none', isEntrada)
      helpEntrada.innerHTML = isConsignacionDev
        ? 'En <strong>devolución de consignación</strong> registra el <strong>ingreso unitario</strong> por producto. No se solicita precio de compra.'
        : 'En <strong>entrada</strong>, el precio de venta queda como el del producto (última mercadería registrada).'
      const requiresClient = !isEntrada || isConsignacionDev
      clienteWrap.classList.toggle('d-none', !requiresClient)
      consignacionWrap.classList.toggle('d-none', !isConsignacionDev)
      clienteWrap.classList.toggle('col-lg-5', isConsignacionDev)
      clienteWrap.classList.toggle('col-lg-12', !isConsignacionDev)
      consignacionWrap.classList.toggle('col-lg-7', isConsignacionDev)
      if (!requiresClient) clienteSelect.value = ''
      document
        .querySelectorAll('.move-col-precio-compra')
        .forEach((el) => el.classList.toggle('d-none', isConsignacionDev))
      document
        .querySelectorAll('.move-col-precio-venta')
        .forEach((el) => el.classList.remove('d-none'))

      draftPrecioCompra.disabled = !isEntrada
      draftPrecioVenta.disabled = !isEntrada

      if (selectedProduct) {
        const m = productosMap[selectedProduct._id]
        if (m) {
          if (!isConsignacionDev && m.precio_compra != null)
            draftPrecioCompra.value = String(m.precio_compra)
          if (m.precio_venta != null) draftPrecioVenta.value = String(m.precio_venta)
        }
      }
      if (isConsignacionDev) {
        draftPrecioCompra.value = ''
      }
      updateMotivoHidden()
      if (isConsignacionDev && consignacionDevBlocked && consignacionBanner) {
        consignacionBanner.classList.remove('d-none')
        consignacionBanner.textContent =
          'No hay consignaciones activas para devolver. Debes registrar una consignación antes de usar esta opción.'
      }
      updateConsignacionAvailabilityUi()
      if (isConsignacionDev) loadConsignaciones(clienteSelect?.value || '')
      renderLinesTable()
    }

    async function loadProducts() {
      try {
        const res = await fetch(`${apiBase}/api/products`)
        allProducts = await res.json()
        productosMap = {}
        for (const p of allProducts) {
          productosMap[p._id] = {
            precio_compra: p.precio_compra ?? null,
            precio_venta: p.precio_venta ?? null
          }
        }
      } catch (e) {
        console.error('Error cargando productos', e)
      }
    }
    loadProducts()

    async function loadClients() {
      try {
        const res = await fetch(`${apiBase}/api/clients`)
        allClients = await res.json()
        if (!clienteSelect) return
        clienteSelect.innerHTML =
          '<option value="">Selecciona un cliente...</option>' +
          allClients
            .map(
              (c) =>
                `<option value="${c._id}">${esc(c.nombre)}${c.celular ? ` - ${esc(c.celular)}` : ''}</option>`
            )
            .join('')
      } catch (e) {
        console.error('Error cargando clientes', e)
      }
    }
    loadClients()

    async function loadConsignaciones(clienteId = '') {
      try {
        const q = clienteId ? `?cliente_id=${encodeURIComponent(clienteId)}` : ''
        const res = await fetch(`${apiBase}/api/inventory-movements/consignaciones${q}`)
        const data = await res.json()
        consignaciones = Array.isArray(data?.consignaciones) ? data.consignaciones : []
        setConsignacionDevState(
          consignaciones.length > 0,
          consignaciones.length
            ? ''
            : 'No hay consignaciones activas para este cliente. Registra una consignación antes de hacer una devolución.'
        )
        consignacionSelect.innerHTML =
          '<option value="">Selecciona una consignación...</option>' +
          consignaciones
            .map((c, idx) => {
              const fecha = new Date(c.fecha).toLocaleDateString('es-MX')
              const cliente = c.cliente_id?.nombre || 'Cliente'
              return `<option value="${idx}">${fecha} · ${esc(cliente)} · ${c.total_productos} productos · ${c.total_cantidad} uds.</option>`
            })
            .join('')
        updateConsignacionAvailabilityUi()
      } catch (e) {
        console.error('Error cargando consignaciones', e)
        consignaciones = []
        setConsignacionDevState(false, 'No fue posible cargar las consignaciones disponibles.')
        consignacionSelect.innerHTML =
          '<option value="">No se pudieron cargar las consignaciones</option>'
        updateConsignacionAvailabilityUi()
      }
    }

    clienteSelect?.addEventListener('change', () => {
      if (isConsignacionDevMode()) loadConsignaciones(clienteSelect.value || '')
    })

    loadConsignacionBtn?.addEventListener('click', () => {
      if (!consignaciones.length) {
        alert('No hay consignaciones activas para cargar.')
        return
      }
      const idx = Number(consignacionSelect?.value)
      if (!Number.isFinite(idx) || idx < 0 || !consignaciones[idx]) {
        alert('Selecciona una consignación para cargar los productos.')
        return
      }
      const src = consignaciones[idx]
      if (src?.cliente_id?._id) {
        clienteSelect.value = String(src.cliente_id._id)
      }
      lines = (src.items || []).map((it: any) => {
        const pid = String(it.producto_id || '')
        const pm = productosMap[pid] || {}
        return {
          producto_id: pid,
          nombre: it.producto_nombre || '—',
          codigo: it.codigo || '',
          cantidad: Math.max(1, Number(it.cantidad || 1)),
          precio_compra: null,
          precio_venta:
            pm.precio_venta != null && Number.isFinite(Number(pm.precio_venta))
              ? Number(pm.precio_venta)
              : null
        }
      })
      renderLinesTable()
    })

    function renderDropdown(query: string) {
      const q = query.toLowerCase().trim()
      const filtered = q
        ? allProducts.filter(
            (p) => p.nombre.toLowerCase().includes(q) || (p.codigo || '').toLowerCase().includes(q)
          )
        : allProducts

      if (!filtered.length) {
        dropdown.innerHTML = `<div class="list-group-item text-muted small py-2 text-center">Sin resultados</div>`
      } else {
        dropdown.innerHTML = filtered
          .map(
            (p) => `
          <button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2 px-3 py-2" data-pid="${p._id}">
            <div class="flex-grow-1 min-w-0">
              <div class="fw-semibold small text-truncate">${esc(p.nombre)}</div>
              ${p.codigo ? `<div class="text-muted" style="font-size:.72rem;">${esc(p.codigo)}</div>` : ''}
            </div>
            ${p.stock != null ? `<span class="badge bg-secondary-subtle text-secondary flex-shrink-0" style="font-size:.7rem;">${p.stock} uds</span>` : ''}
          </button>`
          )
          .join('')

        dropdown.querySelectorAll('button[data-pid]').forEach((btn) => {
          btn.addEventListener('mousedown', (e) => {
            e.preventDefault()
            const pid = (btn as HTMLElement).dataset.pid
            const product = allProducts.find((p) => p._id === pid)
            if (product) selectProduct(product)
          })
        })
      }
      dropdown.style.display = ''
    }

    function selectProduct(product: any) {
      selectedProduct = product
      prodHidden.value = product._id
      searchInput.value = `${product.nombre}${product.codigo ? ` (${product.codigo})` : ''}`
      dropdown.style.display = 'none'
      clearBtn.style.display = ''
      const m = productosMap[product._id]
      if (m) {
        draftPrecioCompra.value = m.precio_compra != null ? String(m.precio_compra) : ''
        draftPrecioVenta.value = m.precio_venta != null ? String(m.precio_venta) : ''
      }
    }

    function clearProductSelection() {
      selectedProduct = null
      prodHidden.value = ''
      searchInput.value = ''
      dropdown.style.display = 'none'
      clearBtn.style.display = 'none'
    }

    searchInput?.addEventListener('input', () => renderDropdown(searchInput.value))
    searchInput?.addEventListener('focus', () => renderDropdown(searchInput.value))
    searchInput?.addEventListener('blur', () => {
      setTimeout(() => {
        dropdown.style.display = 'none'
      }, 150)
    })
    clearBtn?.addEventListener('click', clearProductSelection)

    function parseMoney(v: string) {
      const n = Number(v)
      return v === '' || Number.isNaN(n) ? null : n
    }

    function addLineFromDraft() {
      if (form.dataset.editId || form.dataset.editTransaccionId) return
      if (!selectedProduct) {
        searchInput?.focus()
        return
      }
      const cant = Math.max(1, parseInt(draftCantidad.value, 10) || 1)
      const tipo = getTipoActual()
      const isConsignacionDev =
        tipo === 'entrada' && motivoHidden.value === 'consignacion_devolucion'
      let pc: number | null = null
      let pv: number | null = null
      pc = isConsignacionDev ? null : parseMoney(draftPrecioCompra.value)
      pv = parseMoney(draftPrecioVenta.value)

      const pid = selectedProduct._id
      const existing = lines.findIndex((l) => l.producto_id === pid)
      if (existing >= 0) {
        lines[existing].cantidad += cant
        if (!isConsignacionDev && pc != null) lines[existing].precio_compra = pc
        if (pv != null) lines[existing].precio_venta = pv
      } else {
        lines.push({
          producto_id: pid,
          nombre: selectedProduct.nombre,
          codigo: selectedProduct.codigo || '',
          cantidad: cant,
          precio_compra: isConsignacionDev ? null : pc,
          precio_venta: pv
        })
      }

      draftCantidad.value = '1'
      clearProductSelection()
      renderLinesTable()
    }

    addLineBtn?.addEventListener('click', addLineFromDraft)

    function removeLine(index: number) {
      lines.splice(index, 1)
      renderLinesTable()
    }

    function renderLinesTable() {
      const tipo = getTipoActual()
      const isEntrada = tipo === 'entrada'
      const isConsignacionDev = isEntrada && motivoHidden.value === 'consignacion_devolucion'
      if (!lines.length) {
        linesEmpty.style.display = ''
        linesBody.querySelectorAll('tr.move-line-row').forEach((r) => r.remove())
        return
      }
      linesEmpty.style.display = 'none'
      linesBody.querySelectorAll('tr.move-line-row').forEach((r) => r.remove())

      lines.forEach((line, idx) => {
        const tr = document.createElement('tr')
        tr.className = 'move-line-row align-middle'
        const editing = Boolean(form.dataset.editId || form.dataset.editTransaccionId)
        const pcCell = `<td class="text-end move-col-precio-compra ${isConsignacionDev ? 'd-none' : ''}">${isConsignacionDev ? '<span class="text-muted small">—</span>' : `<input type="number" class="form-control form-control-sm text-end move-line-pc" data-i="${idx}" min="0" step="0.01" value="${line.precio_compra ?? ''}" ${!isEntrada ? 'disabled title="Solo previsualización"' : ''} />`}</td>
             <td class="text-end move-col-precio-venta"><input type="number" class="form-control form-control-sm text-end move-line-pv" data-i="${idx}" min="0" step="0.01" value="${line.precio_venta ?? ''}" ${!isEntrada ? 'disabled title="Solo previsualización"' : ''} /></td>`

        tr.innerHTML = `
          <td>
            <div class="fw-semibold small">${esc(line.nombre)}</div>
            ${line.codigo ? `<div class="text-muted" style="font-size:.72rem;">${esc(line.codigo)}</div>` : ''}
          </td>
          <td class="text-center">
            <input type="number" class="form-control form-control-sm text-center move-line-qty" data-i="${idx}" min="1" value="${line.cantidad}" ${editing ? '' : ''} />
          </td>
          ${pcCell}
          <td class="text-center">
            <button type="button" class="btn btn-sm btn-icon text-danger move-line-remove" data-i="${idx}" title="Quitar" ${editing ? 'style="display:none"' : ''}><i class="ri-close-line"></i></button>
          </td>`

        linesBody.appendChild(tr)
      })

      linesBody.querySelectorAll('.move-line-qty').forEach((inp) => {
        inp.addEventListener('change', () => {
          const i = Number((inp as HTMLInputElement).dataset.i)
          const v = Math.max(1, parseInt((inp as HTMLInputElement).value, 10) || 1)
          if (lines[i]) lines[i].cantidad = v
        })
      })
      linesBody.querySelectorAll('.move-line-pc').forEach((inp) => {
        inp.addEventListener('change', () => {
          const i = Number((inp as HTMLInputElement).dataset.i)
          const v = parseMoney((inp as HTMLInputElement).value)
          if (lines[i]) lines[i].precio_compra = v
        })
      })
      linesBody.querySelectorAll('.move-line-pv').forEach((inp) => {
        inp.addEventListener('change', () => {
          const i = Number((inp as HTMLInputElement).dataset.i)
          const v = parseMoney((inp as HTMLInputElement).value)
          if (lines[i]) lines[i].precio_venta = v
        })
      })
      linesBody.querySelectorAll('.move-line-remove').forEach((btn) => {
        btn.addEventListener('click', () => removeLine(Number((btn as HTMLElement).dataset.i)))
      })
    }

    tipoEntradaRadio?.addEventListener('change', () => {
      if (consignacionDevBlocked && consignacionDevRadio?.checked) {
        consignacionDevRadio.checked = false
        const compraRadio = motivoEntradaGrp?.querySelector('#motivoCompra') as HTMLInputElement
        if (compraRadio) compraRadio.checked = true
      }
      syncTipo()
    })
    tipoSalidaRadio?.addEventListener('change', () => {
      if (lines.length && !form.dataset.editId && !form.dataset.editTransaccionId) {
        if (!confirm('Cambiar el tipo vaciará la lista de productos. ¿Continuar?')) {
          tipoEntradaRadio.checked = true
          tipoSalidaRadio.checked = false
          return
        }
        lines = []
      }
      syncTipo()
    })
    motivoEntradaGrp?.querySelectorAll('input[type="radio"]').forEach((r) =>
      r.addEventListener('change', () => {
        if (
          r instanceof HTMLInputElement &&
          r.id === 'motivoConsignacionDev' &&
          consignacionDevBlocked
        ) {
          r.checked = false
          const compraRadio = motivoEntradaGrp?.querySelector('#motivoCompra') as HTMLInputElement
          if (compraRadio) compraRadio.checked = true
          alert('No hay consignaciones activas para devolver.')
          updateMotivoHidden()
          syncTipo()
          return
        }
        updateMotivoHidden()
        syncTipo()
      })
    )
    motivoSalidaGrp?.querySelectorAll('input[type="radio"]').forEach((r) =>
      r.addEventListener('change', () => {
        updateMotivoHidden()
        syncTipo()
      })
    )
    syncTipo()

    window.movementModalLoadEdit = (movement: any) => {
      delete form.dataset.editTransaccionId
      form.dataset.editId = movement._id
      lines = []
      const pid = movement.producto_id?._id || movement.producto_id || ''
      const nombre = movement.producto_id?.nombre || '—'
      const codigo = movement.producto_id?.codigo || ''
      lines.push({
        producto_id: pid,
        nombre,
        codigo,
        cantidad: Number(movement.cantidad || 1),
        precio_compra: movement.precio_compra != null ? Number(movement.precio_compra) : null,
        precio_venta: movement.precio_venta != null ? Number(movement.precio_venta) : null
      })

      const tipo = movement.tipo_movimiento || 'entrada'
      tipoEntradaRadio.checked = tipo === 'entrada'
      tipoSalidaRadio.checked = tipo === 'salida'

      const motivo = movement.motivo || ''
      if (tipo === 'entrada') {
        const mR = motivoEntradaGrp.querySelector(`input[value="${motivo}"]`) as HTMLInputElement
        if (mR) {
          mR.checked = true
        }
      } else {
        const mR = motivoSalidaGrp.querySelector(`input[value="${motivo}"]`) as HTMLInputElement
        if (mR) {
          mR.checked = true
        }
      }

      ;(document.getElementById('moveObservacion') as HTMLTextAreaElement).value =
        movement.observacion || ''
      clienteSelect.value = String(movement.cliente_id?._id || movement.cliente_id || '')
      updateMotivoHidden()
      syncTipo()
      draftSection.classList.add('d-none')
      addLineBtn.disabled = true
      editNotice.innerHTML =
        '<i class="ri-information-line me-1"></i>Estás editando un movimiento. Ajustá cantidad o precios y guardá.'
      editNotice.classList.remove('d-none')
      tipoEntradaRadio.disabled = true
      tipoSalidaRadio.disabled = true
      const titleEl = document.querySelector('#createMovementModal .modal-title')
      if (titleEl) titleEl.textContent = 'Editar movimiento'
      const btnSubmit = document.getElementById('moveSubmitBtn') as HTMLButtonElement
      if (btnSubmit) btnSubmit.innerHTML = '<i class="ri-check-line me-1"></i>Actualizar'
    }

    window.movementModalLoadTransactionEdit = (apiLines: any[], tid: string) => {
      delete form.dataset.editId
      form.dataset.editTransaccionId = tid
      if (!apiLines?.length) return
      lines = apiLines.map((m) => ({
        movementLineId: String(m._id),
        producto_id: String(m.producto_id?._id || m.producto_id || ''),
        nombre: m.producto_id?.nombre || '—',
        codigo: m.producto_id?.codigo || '',
        cantidad: Math.max(1, Number(m.cantidad || 1)),
        precio_compra: m.precio_compra != null ? Number(m.precio_compra) : null,
        precio_venta: m.precio_venta != null ? Number(m.precio_venta) : null
      }))

      const first = apiLines[0]
      const tipo = first.tipo_movimiento || 'entrada'
      tipoEntradaRadio.checked = tipo === 'entrada'
      tipoSalidaRadio.checked = tipo === 'salida'

      const motivo = first.motivo || ''
      if (tipo === 'entrada') {
        const mR = motivoEntradaGrp.querySelector(`input[value="${motivo}"]`) as HTMLInputElement
        if (mR) mR.checked = true
      } else {
        const mR = motivoSalidaGrp.querySelector(`input[value="${motivo}"]`) as HTMLInputElement
        if (mR) mR.checked = true
      }

      const uid = first.usuario_id?._id || first.usuario_id
      if (usuarioInput && uid) usuarioInput.value = String(uid)
      clienteSelect.value = String(first.cliente_id?._id || first.cliente_id || '')
      ;(document.getElementById('moveObservacion') as HTMLTextAreaElement).value =
        first.observacion || ''
      updateMotivoHidden()
      syncTipo()
      draftSection.classList.add('d-none')
      addLineBtn.disabled = true
      editNotice.innerHTML =
        '<i class="ri-information-line me-1"></i>Estás editando una <strong>transacción</strong> con varios productos. Ajustá cantidades o precios y guardá.'
      editNotice.classList.remove('d-none')
      tipoEntradaRadio.disabled = true
      tipoSalidaRadio.disabled = true
      const titleEl = document.querySelector('#createMovementModal .modal-title')
      if (titleEl) titleEl.textContent = 'Editar transacción'
      const btnSubmit = document.getElementById('moveSubmitBtn') as HTMLButtonElement
      if (btnSubmit) btnSubmit.innerHTML = '<i class="ri-check-line me-1"></i>Actualizar'
    }

    function resetModal() {
      form.reset()
      delete form.dataset.editId
      delete form.dataset.editTransaccionId
      lines = []
      consignaciones = []
      consignacionDevBlocked = false
      clearProductSelection()
      draftCantidad.value = '1'
      draftPrecioCompra.value = ''
      draftPrecioVenta.value = ''
      clienteSelect.value = ''
      tipoEntradaRadio.checked = true
      tipoSalidaRadio.checked = false
      tipoEntradaRadio.disabled = false
      tipoSalidaRadio.disabled = false
      draftSection.classList.remove('d-none')
      addLineBtn.disabled = false
      editNotice.classList.add('d-none')
      if (consignacionDevRadio) consignacionDevRadio.disabled = false
      if (consignacionBanner) {
        consignacionBanner.textContent = ''
        consignacionBanner.classList.add('d-none')
      }
      consignacionSelect.innerHTML = '<option value="">Selecciona una consignación...</option>'
      const titleEl = document.getElementById('createMovementModal')?.querySelector('.modal-title')
      if (titleEl) titleEl.textContent = 'Nuevo movimiento'
      const btnSubmit = document.getElementById('moveSubmitBtn') as HTMLButtonElement
      if (btnSubmit) btnSubmit.innerHTML = '<i class="ri-check-line me-1"></i>Registrar movimiento'
      syncTipo()
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      updateMotivoHidden()
      if (isConsignacionDevMode() && consignacionDevBlocked) {
        alert('No hay consignaciones activas para registrar una devolución.')
        return
      }
      if (!lines.length) {
        alert('Agregá al menos un producto a la lista.')
        return
      }

      const tipo = getTipoActual()
      const requiresClient = tipo === 'salida' || motivoHidden.value === 'consignacion_devolucion'
      if (requiresClient && !clienteSelect?.value) {
        alert('Debes seleccionar un cliente para este movimiento.')
        clienteSelect?.focus()
        return
      }

      const btn = document.getElementById('moveSubmitBtn') as HTMLButtonElement
      const isEditMode = Boolean(form.dataset.editId || form.dataset.editTransaccionId)
      if (btn) {
        btn.disabled = true
        btn.innerHTML = '<i class="ri-loader-4-line ri-spin me-1"></i>Guardando...'
      }

      const movementId = form.dataset.editId
      const transaccionId = form.dataset.editTransaccionId

      try {
        if (transaccionId) {
          for (const l of lines) {
            if (!l.movementLineId) throw new Error('Falta id de línea')
          }
          const url = `${apiBase}/api/inventory-movements/transaccion/${encodeURIComponent(transaccionId)}`
          const payload = {
            motivo: motivoHidden.value,
            cliente_id: clienteSelect?.value || null,
            usuario_id: usuarioInput?.value || '',
            observacion:
              (document.getElementById('moveObservacion') as HTMLTextAreaElement)?.value || '',
            items: lines.map((l) => ({
              movement_id: l.movementLineId,
              producto_id: l.producto_id,
              cantidad: l.cantidad,
              precio_compra: tipo === 'entrada' ? l.precio_compra : null,
              precio_venta: tipo === 'entrada' ? l.precio_venta : null
            }))
          }
          const response = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          })
          if (!response.ok) {
            const err = await response.json().catch(() => ({}))
            throw new Error(
              (err as { message?: string }).message || 'Error al actualizar la transacción'
            )
          }
        } else if (movementId) {
          const line = lines[0]
          if (!line) throw new Error('Sin línea')
          const url = `${apiBase}/api/inventory-movements/${movementId}`
          const payload = {
            producto_id: line.producto_id,
            cliente_id: clienteSelect?.value || null,
            tipo_movimiento: tipo,
            cantidad: line.cantidad,
            precio_compra: tipo === 'entrada' ? line.precio_compra : null,
            precio_venta: tipo === 'entrada' ? line.precio_venta : null,
            motivo: motivoHidden.value,
            usuario_id: usuarioInput?.value || '',
            observacion:
              (document.getElementById('moveObservacion') as HTMLTextAreaElement)?.value || ''
          }
          const response = await fetch(url, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          })
          if (!response.ok) throw new Error('Error al actualizar')
        } else {
          const items = lines.map((l) => ({
            producto_id: l.producto_id,
            cantidad: l.cantidad,
            precio_compra: tipo === 'entrada' ? l.precio_compra : null,
            precio_venta: tipo === 'entrada' ? l.precio_venta : null
          }))
          const payload = {
            tipo_movimiento: tipo,
            motivo: motivoHidden.value,
            cliente_id: clienteSelect?.value || null,
            usuario_id: usuarioInput?.value || '',
            observacion:
              (document.getElementById('moveObservacion') as HTMLTextAreaElement)?.value || '',
            items
          }
          const response = await fetch(`${apiBase}/api/inventory-movements`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          })
          if (!response.ok) throw new Error('Error al registrar movimientos')
        }

        const modalEl = document.getElementById('createMovementModal')
        if (modalEl) bootstrap.Modal.getInstance(modalEl)?.hide()
      } catch (error) {
        alert(error instanceof Error ? error.message : 'Error al guardar')
      } finally {
        if (btn) {
          btn.disabled = false
          btn.innerHTML = isEditMode
            ? '<i class="ri-check-line me-1"></i>Actualizar'
            : '<i class="ri-check-line me-1"></i>Registrar movimiento'
        }
      }
    })

    const modalEl = document.getElementById('createMovementModal')
    if (modalEl) {
      modalEl.addEventListener('hidden.bs.modal', resetModal)
    }

    function selectProductExternal(product: any) {
      selectProduct(product)
    }
    function clearProductExternal() {
      clearProductSelection()
    }

    window.moveProductoPicker = {
      select: selectProductExternal,
      clear: clearProductExternal,
      getAll: () => allProducts
    }
  })
</script>
