---
import { getAssetPrefix } from '../../../utils/path.js'

export interface Props {
  brandName: boolean
}

const { brandName = false } = Astro.props
---

<!-- Company Logo and Name -->
<div class="mb-3 d-flex align-items-center justify-content-center">
  <img
    src={getAssetPrefix('/assets/img/noryx/NoryxStoreLogo.jpeg')}
    alt="Noryx Store Logo"
    class="me-2"
    style="width: 40px; height: 40px;"
  />
  {brandName && <div class="fs-4 mt-2">Noryx Store</div>}
</div>
