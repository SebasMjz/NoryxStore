---
import { getPathPrefix } from '../../../utils/path.js'
import AdminLayout from '../../layouts/admin/admin-layout.astro'
import PageHeader from '../../components/common/page-header.astro'

// Configure page header with descriptive breadcrumb navigation
const pageHeaderProps = {
  title: 'Productos',
  description: 'Tabla de productos con filtros de inventario y precios',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Productos', class: 'active' }
  ]
}

const iframesrc = getPathPrefix('/tables/datatable/products')
---

<AdminLayout
  title="Productos"
  description="Tabla de productos con filtros de inventario y precios"
  currentPath="tables/datatable"
>
  <PageHeader {...pageHeaderProps} />

  <div class="row">
    <div class="col-12">
      <h2 id="products-datatable">Tabla de productos</h2>
      <p class="mb-4">
        Vista principal para gestion de inventario de productos en una sola sucursal.
      </p>

      <div class="card overflow-hidden">
        <div class="card-body p-0">
          <iframe
            src={iframesrc}
            title="Tabla de productos"
            style="width: 100%; height: 760px; border: 0; display: block;"></iframe>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
