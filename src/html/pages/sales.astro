---
import { getPathPrefix } from '../../utils/path.js'
import AdminLayout from '../layouts/admin/admin-layout.astro'
import PageHeader from '../components/common/page-header.astro'

const pageHeaderProps = {
  title: 'Nueva Venta',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Nueva Venta', class: 'active' }
  ]
}
---

<style is:global>
  .pos-product-card {
    cursor: pointer;
    transition: transform .15s, box-shadow .15s, border-color .15s;
    border: 1.5px solid rgba(255,255,255,.07);
    border-radius: .6rem;
    user-select: none;
  }
  .pos-product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
    border-color: var(--bs-primary);
  }
  .pos-product-card.out-of-stock { opacity:.42; cursor:not-allowed; pointer-events:none; }
  .qty-btn { width:26px; height:26px; padding:0; line-height:1; font-size:.85rem; }
  .cart-row-warn td { background: rgba(255,193,7,.06) !important; }
  .pos-card-accent { height:3px; border-radius:4px 4px 0 0; margin:-1rem -1rem .75rem; }

  /* Category filter pills */
  .cat-pill {
    border-radius: 2rem;
    padding: .25rem .85rem;
    font-size: .78rem;
    font-weight: 500;
    border: 1.5px solid rgba(255,255,255,.12);
    cursor: pointer;
    transition: all .15s;
    background: transparent;
    color: inherit;
  }
  .cat-pill:hover, .cat-pill.active {
    background: var(--bs-primary);
    border-color: var(--bs-primary);
    color: #fff;
  }

  /* Client dropdown */
  #clientDropdown {
    position:absolute; z-index:9999; width:100%; max-height:200px; overflow-y:auto;
    border:1px solid rgba(255,255,255,.12); border-radius:.4rem;
    background:var(--bs-body-bg,#212529); box-shadow:0 8px 24px rgba(0,0,0,.4);
  }
  #clientDropdown .client-option {
    padding:.45rem .75rem; cursor:pointer; font-size:.84rem;
    border-bottom:1px solid rgba(255,255,255,.05);
  }
  #clientDropdown .client-option:hover { background:rgba(111,66,193,.2); }
</style>

<AdminLayout
  title="Nueva Venta — POS"
  description="Punto de venta"
  currentPath="sales"
>
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <PageHeader {...pageHeaderProps} />
    <a href={getPathPrefix('/sales/history')} class="btn btn-outline-secondary btn-sm">
      <i class="ri-history-line me-1"></i>Ver historial
    </a>
  </div>

  <div class="row g-4" style="min-height:82vh;">

    <!-- LEFT: Product browser -->
    <div class="col-lg-7 d-flex flex-column">
      <div class="card flex-grow-1" style="overflow:hidden;">

        <!-- Search + category filter -->
        <div class="card-header border-0 pb-2">
          <div class="input-group mb-2">
            <span class="input-group-text bg-transparent border-end-0 text-muted">
              <i class="ri-search-2-line"></i>
            </span>
            <input type="text" id="posSearch" class="form-control border-start-0 ps-1"
              placeholder="Buscar por nombre o código..." autocomplete="off" />
          </div>
          <!-- Category pills -->
          <div id="catPills" class="d-flex flex-wrap gap-2">
            <button class="cat-pill active" data-cat="">Todos</button>
          </div>
        </div>

        <!-- Product grid -->
        <div class="card-body p-3 overflow-auto" style="max-height:calc(82vh - 110px);">
          <div id="posProductGrid" class="row g-3">
            <div class="col-12 text-center text-muted py-5">
              <i class="ri-loader-4-line ri-spin fs-2"></i>
              <p class="mt-2 mb-0 small">Cargando productos...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Cart + Checkout -->
    <div class="col-lg-5 d-flex flex-column gap-3">

      <!-- Cart -->
      <div class="card flex-grow-1" style="overflow:hidden;">
        <div class="card-header border-0 d-flex align-items-center justify-content-between py-2">
          <h6 class="mb-0 fw-semibold d-flex align-items-center gap-2">
            <i class="ri-shopping-bag-3-line text-primary"></i>
            Carrito
            <span id="cartCount" class="badge bg-primary d-none">0</span>
          </h6>
          <button class="btn btn-sm btn-outline-secondary" id="clearCartBtn" title="Limpiar">
            <i class="ri-delete-bin-line"></i>
          </button>
        </div>

        <div id="cartEmpty" class="d-flex flex-column align-items-center justify-content-center text-muted py-5">
          <i class="ri-shopping-cart-line" style="font-size:2.8rem;opacity:.22;"></i>
          <p class="mt-2 mb-0 small">Haz clic en un producto para agregarlo</p>
        </div>

        <div id="cartBody" class="d-none overflow-auto" style="max-height:30vh;">
          <table class="table table-sm mb-0">
            <thead style="position:sticky;top:0;z-index:1;">
              <tr class="table-dark">
                <th class="ps-3">Producto</th>
                <th class="text-center" style="width:115px;">Cant.</th>
                <th class="text-end" style="width:90px;">Subtotal</th>
                <th style="width:32px;"></th>
              </tr>
            </thead>
            <tbody id="cartTableBody"></tbody>
          </table>
        </div>

        <div id="cartFooter" class="card-footer border-top d-none">
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted small"><span id="cartItemsCount">0</span> ítem(s)</span>
            <div class="text-end">
              <div class="text-muted" style="font-size:.68rem;letter-spacing:.06em;">TOTAL</div>
              <div class="fs-4 fw-bold text-primary" id="cartTotal">$0.00</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Checkout -->
      <div class="card">
        <div class="card-body">
          <h6 class="fw-semibold mb-3 d-flex align-items-center gap-2">
            <i class="ri-receipt-2-line text-primary"></i>Datos de la Venta
          </h6>

          <!-- Client -->
          <div class="mb-3">
            <label class="form-label small text-muted">Cliente</label>
            <div class="d-flex gap-2 align-items-start">
              <div class="position-relative flex-grow-1">
                <input type="text" id="clientSearch" class="form-control form-control-sm"
                  placeholder="Buscar por nombre o celular..." autocomplete="off" />
                <div id="clientDropdown" class="d-none"></div>
              </div>
              <button class="btn btn-sm btn-outline-primary flex-shrink-0" id="addClientBtn" title="Nuevo cliente">
                <i class="ri-user-add-line"></i>
              </button>
            </div>
            <div id="selectedClientBadge" class="d-none mt-2">
              <span class="badge text-bg-secondary d-inline-flex align-items-center gap-1 pe-1">
                <i class="ri-user-line"></i>
                <span id="selectedClientName"></span>
                <button type="button" id="clearClientBtn" class="btn-close btn-close-white ms-1" style="font-size:.5rem;"></button>
              </span>
            </div>
          </div>
          <input type="hidden" id="selectedClientId" />

          <!-- Payment method -->
          <div class="mb-3">
            <label class="form-label small text-muted">Método de Pago <span class="text-danger">*</span></label>
            <div id="posPaymentMethods" class="d-flex flex-wrap gap-2">
              <span class="text-muted small">Cargando...</span>
            </div>
          </div>

          <!-- Observations -->
          <div class="mb-3">
            <label class="form-label small text-muted">Observaciones</label>
            <textarea class="form-control form-control-sm" id="posObservacion" rows="2"
              placeholder="Nota opcional..."></textarea>
          </div>

          <!-- Stock warning -->
          <div id="stockWarningBanner" class="alert alert-warning d-none py-2 small mb-3">
            <i class="ri-error-warning-line me-1"></i>
            <strong>Atención:</strong> Uno o más productos superan el stock disponible. El stock quedará negativo.
          </div>

          <button class="btn btn-primary w-100 py-2 fw-semibold" id="completeSaleBtn" disabled>
            <i class="ri-check-double-line me-2"></i>Completar Venta
          </button>
        </div>
      </div>

    </div>
  </div>
</AdminLayout>

<!-- Quick new client modal -->
<div class="modal fade" id="quickClientModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title mb-0"><i class="ri-user-add-line me-2"></i>Nuevo Cliente</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="quickClientForm">
          <div class="mb-3">
            <label class="form-label small">Nombre <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm" id="qcNombre" required placeholder="Nombre completo" />
          </div>
          <div class="mb-3">
            <label class="form-label small">Celular</label>
            <input type="text" class="form-control form-control-sm" id="qcCelular" placeholder="Ej: 0991234567" />
          </div>
          <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-sm btn-primary" id="qcSubmit">Guardar</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
  <div id="posToast" class="toast align-items-center border-0 text-bg-success" role="alert" aria-live="assertive">
    <div class="d-flex">
      <div class="toast-body fw-semibold" id="posToastMsg">Venta completada.</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  const API =
    window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://localhost:4000'
      : ''

  let cart = []
  let allProducts = []
  let allClients = []
  let allCategories = []
  let currentCat = ''
  let selectedPayment = ''
  let selectedClientId = ''

  const fmt = (n) => '$' + Number(n || 0).toFixed(2)
  const esc = (s) =>
    String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')

  document.addEventListener('DOMContentLoaded', () => {
    Promise.all([loadProducts(), loadClients(), loadPaymentMethods()])

    document.getElementById('posSearch').addEventListener('input', (e) => renderProducts(e.target.value))
    document.getElementById('clearCartBtn').addEventListener('click', clearCart)
    document.getElementById('completeSaleBtn').addEventListener('click', completeSale)
    document.getElementById('addClientBtn').addEventListener('click', openQuickClient)
    document.getElementById('clearClientBtn').addEventListener('click', clearClient)
    document.getElementById('quickClientForm').addEventListener('submit', createQuickClient)
    initClientSearch()
  })

  // ── Categories ──────────────────────────────────────────────────────
  async function loadCategories() {
    try {
      const res = await fetch(API + '/api/categories')
      allCategories = (await res.json()).filter((c) => c.activo)
      renderCatPills()
    } catch { /* no-op */ }
  }

  function renderCatPills() {
    const container = document.getElementById('catPills')
    const extra = allCategories.map((c) =>
      `<button class="cat-pill" data-cat="${c._id}">${esc(c.nombre)}</button>`
    ).join('')
    container.innerHTML = `<button class="cat-pill active" data-cat="">Todos</button>${extra}`
    container.querySelectorAll('.cat-pill').forEach((btn) => {
      btn.addEventListener('click', function () {
        container.querySelectorAll('.cat-pill').forEach((b) => b.classList.remove('active'))
        this.classList.add('active')
        currentCat = this.dataset.cat
        renderProducts(document.getElementById('posSearch').value)
      })
    })
  }

  // ── Products ─────────────────────────────────────────────────────────
  async function loadProducts() {
    try {
      const [prodRes] = await Promise.all([
        fetch(API + '/api/products'),
        loadCategories()
      ])
      allProducts = (await prodRes.json()).filter((p) => p.activo)
      renderProducts('')
    } catch {
      document.getElementById('posProductGrid').innerHTML =
        '<div class="col-12 text-center text-danger py-4"><i class="ri-error-warning-line"></i> Error al cargar productos</div>'
    }
  }

  function renderProducts(query) {
    const q = (query || '').toLowerCase().trim()
    const filtered = allProducts.filter((p) => {
      const matchCat = !currentCat || (p.categoria_id?._id || p.categoria_id) === currentCat
      if (!matchCat) return false
      return !q || (p.nombre||'').toLowerCase().includes(q) || (p.codigo||'').toLowerCase().includes(q)
    })

    const grid = document.getElementById('posProductGrid')
    if (!filtered.length) {
      grid.innerHTML = '<div class="col-12 text-center text-muted py-5"><i class="ri-box-3-line fs-2 d-block mb-2"></i>Sin resultados</div>'
      return
    }

    grid.innerHTML = filtered.map((p) => {
      const stock = Number(p.stock || 0)
      const isOut = stock === 0
      const stockClass = isOut ? 'danger' : stock <= 10 ? 'warning' : 'success'
      const stockLabel = isOut ? 'Sin stock' : `${stock} unid.`
      const accentBg = isOut ? '#dc3545' : stock <= 10 ? '#ffc107' : 'linear-gradient(90deg,var(--bs-primary),#0dcaf0)'
      const catName = p.categoria_id?.nombre || ''

      return `
        <div class="col-lg-4 col-md-4 col-6">
          <div class="card card-body p-3 pos-product-card h-100 ${isOut ? 'out-of-stock' : ''}"
            data-id="${p._id}" data-nombre="${esc(p.nombre)}" data-codigo="${esc(p.codigo||'')}"
            data-precio="${p.precio_venta||0}" data-stock="${stock}">
            <div class="pos-card-accent" style="background:${accentBg};"></div>
            <div class="d-flex justify-content-between align-items-start mb-2">
              <span class="badge text-bg-${stockClass}" style="font-size:.62rem;">${stockLabel}</span>
              ${catName ? `<span class="badge text-bg-secondary" style="font-size:.6rem;">${esc(catName)}</span>` : ''}
            </div>
            <div class="fw-semibold text-truncate mb-1" style="font-size:.85rem;" title="${esc(p.nombre)}">${esc(p.nombre)}</div>
            <div class="text-muted mb-2" style="font-size:.7rem;">${esc(p.codigo || '—')}</div>
            <div class="mt-auto fw-bold text-primary">${fmt(p.precio_venta)}</div>
          </div>
        </div>`
    }).join('')

    grid.querySelectorAll('.pos-product-card:not(.out-of-stock)').forEach((card) => {
      card.addEventListener('click', () =>
        addToCart({
          producto_id: card.dataset.id,
          nombre: card.dataset.nombre,
          codigo: card.dataset.codigo,
          precio_unitario: Number(card.dataset.precio),
          stockDisponible: Number(card.dataset.stock)
        })
      )
    })
  }

  // ── Cart ─────────────────────────────────────────────────────────────
  function addToCart(item) {
    const existing = cart.find((c) => c.producto_id === item.producto_id)
    if (existing) existing.cantidad += 1
    else cart.push({ ...item, cantidad: 1 })
    renderCart()
  }

  function removeFromCart(id) { cart = cart.filter((c) => c.producto_id !== id); renderCart() }

  function updateQty(id, val) {
    const item = cart.find((c) => c.producto_id === id)
    if (!item) return
    const qty = parseInt(val, 10)
    if (isNaN(qty) || qty < 1) return
    item.cantidad = qty
    renderCart()
  }

  function clearCart() { cart = []; renderCart() }

  function hasStockWarning() { return cart.some((c) => c.cantidad > c.stockDisponible) }

  function renderCart() {
    const empty = document.getElementById('cartEmpty')
    const body  = document.getElementById('cartBody')
    const footer = document.getElementById('cartFooter')
    const tbody = document.getElementById('cartTableBody')
    const countBadge = document.getElementById('cartCount')
    const itemsCount = document.getElementById('cartItemsCount')
    const totalEl = document.getElementById('cartTotal')
    const completeBtn = document.getElementById('completeSaleBtn')
    const warnBanner = document.getElementById('stockWarningBanner')

    if (!cart.length) {
      empty.classList.remove('d-none')
      body.classList.add('d-none')
      footer.classList.add('d-none')
      countBadge.classList.add('d-none')
      warnBanner.classList.add('d-none')
      completeBtn.disabled = true
      completeBtn.innerHTML = '<i class="ri-check-double-line me-2"></i>Completar Venta'
      completeBtn.className = 'btn btn-primary w-100 py-2 fw-semibold'
      return
    }

    empty.classList.add('d-none')
    body.classList.remove('d-none')
    footer.classList.remove('d-none')
    countBadge.classList.remove('d-none')

    const total = cart.reduce((s, c) => s + c.precio_unitario * c.cantidad, 0)
    const totalItems = cart.reduce((s, c) => s + c.cantidad, 0)
    const warn = hasStockWarning()

    countBadge.textContent = String(totalItems)
    itemsCount.textContent = String(totalItems)
    totalEl.textContent = fmt(total)
    warnBanner.classList.toggle('d-none', !warn)

    tbody.innerHTML = cart.map((item) => {
      const over = item.cantidad > item.stockDisponible
      const warnIcon = over ? `<i class="ri-error-warning-line text-warning ms-1" title="Supera stock (${item.stockDisponible})"></i>` : ''
      return `
        <tr class="${over ? 'cart-row-warn' : ''}">
          <td class="ps-3 align-middle" style="min-width:120px;">
            <div class="fw-semibold d-flex align-items-center" style="font-size:.82rem;">${esc(item.nombre)}${warnIcon}</div>
            <div class="text-muted" style="font-size:.68rem;">${fmt(item.precio_unitario)} c/u · stock: ${item.stockDisponible}</div>
          </td>
          <td class="text-center align-middle">
            <div class="d-flex align-items-center justify-content-center gap-1">
              <button class="btn btn-outline-secondary qty-btn qty-minus" data-id="${item.producto_id}">−</button>
              <input type="number" min="1" value="${item.cantidad}" class="form-control form-control-sm text-center qty-input"
                data-id="${item.producto_id}" style="width:44px;padding:2px 4px;font-size:.8rem;" />
              <button class="btn btn-outline-secondary qty-btn qty-plus" data-id="${item.producto_id}">+</button>
            </div>
          </td>
          <td class="text-end align-middle fw-semibold ${over?'text-warning':''}" style="font-size:.82rem;">${fmt(item.precio_unitario * item.cantidad)}</td>
          <td class="align-middle pe-2">
            <button class="btn btn-sm btn-icon text-danger remove-item" data-id="${item.producto_id}"><i class="ri-close-line"></i></button>
          </td>
        </tr>`
    }).join('')

    tbody.querySelectorAll('.qty-minus').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = cart.find((c) => c.producto_id === btn.dataset.id)
        if (item) { if (item.cantidad > 1) { item.cantidad--; renderCart() } else removeFromCart(btn.dataset.id) }
      })
    })
    tbody.querySelectorAll('.qty-plus').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = cart.find((c) => c.producto_id === btn.dataset.id)
        if (item) { item.cantidad++; renderCart() }
      })
    })
    tbody.querySelectorAll('.qty-input').forEach((inp) => {
      inp.addEventListener('change', () => updateQty(inp.dataset.id, inp.value))
    })
    tbody.querySelectorAll('.remove-item').forEach((btn) => {
      btn.addEventListener('click', () => removeFromCart(btn.dataset.id))
    })

    completeBtn.disabled = !selectedPayment
    if (warn) {
      completeBtn.innerHTML = '<i class="ri-error-warning-line me-2"></i>Completar (stock negativo)'
      completeBtn.className = 'btn btn-warning w-100 py-2 fw-semibold'
    } else {
      completeBtn.innerHTML = '<i class="ri-check-double-line me-2"></i>Completar Venta'
      completeBtn.className = 'btn btn-primary w-100 py-2 fw-semibold'
    }
  }

  // ── Clients ──────────────────────────────────────────────────────────
  async function loadClients() {
    try {
      const res = await fetch(API + '/api/clients')
      allClients = await res.json()
    } catch { /* no-op */ }
  }

  function initClientSearch() {
    const input = document.getElementById('clientSearch')
    const dropdown = document.getElementById('clientDropdown')

    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase()
      if (!q) { dropdown.classList.add('d-none'); return }
      const matches = allClients.filter(
        (c) => (c.nombre||'').toLowerCase().includes(q) || (c.celular||'').toLowerCase().includes(q)
      ).slice(0, 8)

      if (!matches.length) {
        dropdown.innerHTML = '<div class="client-option text-muted">Sin resultados</div>'
      } else {
        dropdown.innerHTML = matches.map((c) =>
          `<div class="client-option" data-id="${c._id}" data-nombre="${esc(c.nombre)}">
            <span class="fw-medium">${esc(c.nombre)}</span>
            ${c.celular ? `<span class="text-muted ms-2 small">${esc(c.celular)}</span>` : ''}
          </div>`
        ).join('')
        dropdown.querySelectorAll('.client-option[data-id]').forEach((opt) =>
          opt.addEventListener('click', () => selectClient(opt.dataset.id, opt.dataset.nombre))
        )
      }
      dropdown.classList.remove('d-none')
    })

    document.addEventListener('click', (e) => {
      if (!input.contains(e.target) && !dropdown.contains(e.target)) dropdown.classList.add('d-none')
    })
  }

  function selectClient(id, nombre) {
    selectedClientId = id
    document.getElementById('selectedClientId').value = id
    document.getElementById('selectedClientName').textContent = nombre
    document.getElementById('selectedClientBadge').classList.remove('d-none')
    document.getElementById('clientSearch').value = ''
    document.getElementById('clientDropdown').classList.add('d-none')
  }

  function clearClient() {
    selectedClientId = ''
    document.getElementById('selectedClientId').value = ''
    document.getElementById('selectedClientBadge').classList.add('d-none')
  }

  function openQuickClient() {
    document.getElementById('quickClientForm').reset()
    new bootstrap.Modal(document.getElementById('quickClientModal')).show()
  }

  async function createQuickClient(e) {
    e.preventDefault()
    const nombre = document.getElementById('qcNombre').value.trim()
    const celular = document.getElementById('qcCelular').value.trim()
    if (!nombre) return
    const btn = document.getElementById('qcSubmit')
    btn.disabled = true; btn.textContent = 'Guardando...'
    const user = window.__authUser || {}
    try {
      const res = await fetch(API + '/api/clients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-user-id': user.id||'', 'x-user-name': user.nombre||'' },
        body: JSON.stringify({ nombre, celular })
      })
      if (!res.ok) throw new Error()
      const newClient = await res.json()
      allClients.unshift(newClient)
      selectClient(newClient._id, newClient.nombre)
      bootstrap.Modal.getInstance(document.getElementById('quickClientModal')).hide()
      showToast(`Cliente "${nombre}" creado.`, 'success')
    } catch { showToast('Error al crear el cliente', 'danger') }
    finally { btn.disabled = false; btn.textContent = 'Guardar' }
  }

  // ── Payment methods ──────────────────────────────────────────────────
  async function loadPaymentMethods() {
    try {
      const res = await fetch(API + '/api/settings/payment-methods')
      const data = await res.json()
      renderPaymentButtons(data.methods || ['Efectivo', 'QR'])
    } catch { renderPaymentButtons(['Efectivo', 'QR']) }
  }

  function renderPaymentButtons(methods) {
    const container = document.getElementById('posPaymentMethods')
    container.innerHTML = methods.map((m) =>
      `<button type="button" class="btn btn-sm btn-outline-secondary pay-btn" data-method="${esc(m)}">${esc(m)}</button>`
    ).join('')
    container.querySelectorAll('.pay-btn').forEach((btn) => {
      btn.addEventListener('click', function () {
        container.querySelectorAll('.pay-btn').forEach((b) => {
          b.classList.remove('btn-primary','active'); b.classList.add('btn-outline-secondary')
        })
        this.classList.remove('btn-outline-secondary'); this.classList.add('btn-primary','active')
        selectedPayment = this.dataset.method
        document.getElementById('completeSaleBtn').disabled = !cart.length
      })
    })
  }

  // ── Complete sale ─────────────────────────────────────────────────────
  async function completeSale() {
    if (!cart.length || !selectedPayment) return

    if (hasStockWarning()) {
      const itemsHtml = cart.filter((c) => c.cantidad > c.stockDisponible)
        .map((c) => `<li><strong>${c.nombre}</strong>: pedido ${c.cantidad}, disponible ${c.stockDisponible}</li>`)
        .join('')
      const ok = await window.showConfirm({
        title: 'Stock insuficiente',
        message: `Los siguientes productos quedarán con stock negativo:<ul class="text-start mt-2 mb-0 ps-3">${itemsHtml}</ul>`,
        confirmText: 'Continuar de todas formas',
        type: 'warning'
      })
      if (!ok) return
    }

    const btn = document.getElementById('completeSaleBtn')
    btn.disabled = true
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...'

    const user = window.__authUser || {}
    try {
      const res = await fetch(API + '/api/sales', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-user-id': user.id||'', 'x-user-name': user.nombre||'' },
        body: JSON.stringify({
          cliente_id: selectedClientId || null,
          vendedor_id: user.id || null,
          metodo_pago: selectedPayment,
          observacion: document.getElementById('posObservacion').value.trim(),
          items: cart.map((c) => ({ producto_id: c.producto_id, cantidad: c.cantidad, precio_unitario: c.precio_unitario }))
        })
      })
      if (!res.ok) { const err = await res.json().catch(()=>({})); throw new Error(err.message||'Error') }
      showToast('✓ Venta completada exitosamente.', 'success')
      clearCart(); clearClient()
      selectedPayment = ''
      document.querySelectorAll('.pay-btn').forEach((b) => {
        b.classList.remove('btn-primary','active'); b.classList.add('btn-outline-secondary')
      })
      document.getElementById('posObservacion').value = ''
      await loadProducts()
    } catch (err) {
      showToast(err.message, 'danger')
      renderCart()
    }
  }

  // ── Helpers ───────────────────────────────────────────────────────────
  function showToast(msg, type = 'success') {
    const el = document.getElementById('posToast')
    document.getElementById('posToastMsg').textContent = msg
    el.className = `toast align-items-center border-0 text-bg-${type}`
    new bootstrap.Toast(el, { delay: 3500 }).show()
  }
})()
</script>
