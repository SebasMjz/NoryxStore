              </div>
            </div>
          </div>
          <div class="p-3 pb-0">
            <div class="row g-3 sale-detail-meta small">
              <div class="col-sm-6 col-md-4">
                <div class="meta-label">Cliente</div>
                <div class="meta-value">${esc(sale?.cliente_id?.nombre || 'Consumidor final')}</div>
              </div>
              <div class="col-sm-6 col-md-4">
                <div class="meta-label">Vendedor</div>
                <div class="meta-value">${esc(sale?.vendedor_id?.nombre || '—')}</div>
              </div>
              <div class="col-sm-6 col-md-4">
                <div class="meta-label">Pago</div>
                <div class="meta-value">${formatPagoDetailHtml(sale)}</div>
              </div>
              ${sale?.observacion ? `<div class="col-12"><div class="meta-label">Observación</div><div class="meta-value text-body-secondary">${esc(sale.observacion)}</div></div>` : ''}
            </div>
          </div>
          ${
            isAnulada && sale?.motivo_anulacion
              ? `
          <div class="px-3 pb-2">
            <div class="alert alert-danger py-2 mb-0 small">
              <i class="ri-forbid-line me-1"></i><strong>Motivo de anulación:</strong> ${esc(sale.motivo_anulacion)}
            </div>
          </div>`
              : ''
          }
          <div class="table-responsive px-3 pb-3">
            <table class="table table-sm table-hover align-middle mb-0 sale-detail-table">
              <thead>
                <tr>
                  <th scope="col" style="width:88px;">SKU</th>
                  <th scope="col">Producto</th>
                  <th scope="col" class="text-center" style="width:64px;">Cant.</th>
                  <th scope="col" class="text-end" style="width:96px;">P. unit.</th>
                  <th scope="col" class="text-end" style="width:96px;">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                ${details
                  .map(
                    (d) => `
                  <tr>
                    <td class="sku-cell">${esc(d.producto_id?.codigo || '—')}</td>
                    <td class="fw-medium">${esc(d.producto_id?.nombre || '—')}</td>
                    <td class="text-center">${d.cantidad}</td>
                    <td class="text-end">${fmt(d.precio_unitario)}</td>
