---
import { getPathPrefix, getAssetPrefix } from '../../utils/path.js'
import AdminLayout from '../layouts/admin/admin-layout.astro'
import PageHeader from '../components/common/page-header.astro'

const pageHeaderProps = {
  title: 'Ventas',
  breadcrumbs: [
    { label: 'Dashboard', href: getPathPrefix('/dashboard') },
    { label: 'Ventas', class: 'active' }
  ]
}
const receiptLogoUrl = getAssetPrefix('/assets/img/noryx/NoryxStoreLogo.jpeg')
---

<style is:global>
  .caja-card {
    border-radius: 12px;
    border: 1px solid rgba(111, 66, 193, 0.15);
    background: linear-gradient(135deg, rgba(111, 66, 193, 0.07) 0%, rgba(111, 66, 193, 0.02) 100%);
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .caja-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 18px rgba(111, 66, 193, 0.12);
  }
  .caja-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  /* DataTables-identical pagination wrapper */
  .dt-pg-wrap {
    padding: 0.5rem 1rem;
  }
  .dt-pg-wrap .dataTables_info {
    font-size: 0.875rem;
    color: var(--bs-secondary-color);
  }
  .dt-pg-wrap .dataTables_length select {
    width: auto;
    display: inline-block;
  }

  /* Detalle de venta (modal) */
  .sale-detail-dialog .modal-content {
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
  }
  .sale-detail-sheet {
    background: var(--bs-body-bg);
  }
  .sale-detail-head {
    background: linear-gradient(
      135deg,
      rgba(111, 66, 193, 0.14) 0%,
      rgba(111, 66, 193, 0.04) 100%
    ) !important;
  }
  .sale-detail-num {
    font-size: 1.4rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--bs-primary);
    line-height: 1;
  }
  .sale-detail-meta .meta-label {
    color: var(--bs-secondary-color);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }
  .sale-detail-meta .meta-value {
    font-size: 0.9rem;
    font-weight: 500;
  }
  .sale-detail-table thead th {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    background: rgba(35, 38, 45, 0.98) !important;
    color: rgba(255, 255, 255, 0.92) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14) !important;
    padding-top: 0.55rem;
    padding-bottom: 0.55rem;
  }
  .sale-detail-table tbody td {
    font-size: 0.84rem;
    vertical-align: middle;
  }
  .sale-detail-table .sku-cell {
    font-family: ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--bs-secondary-color);
  }
  .sale-detail-totals {
    border-radius: 10px;
    background: rgba(111, 66, 193, 0.06);
    border: 1px solid rgba(111, 66, 193, 0.12);
  }
</style>

<AdminLayout title="Ventas" description="Historial y punto de venta" currentPath="sales">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <PageHeader {...pageHeaderProps} />
    <a href={getPathPrefix('/sales/pos')} class="btn btn-primary align-self-start">
      <i class="ri-shopping-cart-2-line me-1" aria-hidden="true"></i>Nueva venta
    </a>
  </div>

  <!-- ── Caja del período ──────────────────────────────────── -->
  <div class="card mb-4">
    <div
      class="card-header border-0 d-flex align-items-center justify-content-between flex-wrap gap-2"
    >
      <div>
        <h5 class="card-title mb-0">
          <i class="ri-safe-2-line me-2 text-primary"></i>Caja
          <span class="text-muted fw-normal">—</span>
          <span id="cajaPeriodTitle" class="text-primary fw-semibold ms-1">Hoy</span>
        </h5>
      </div>
      <div class="d-flex align-items-center gap-3">
        <!-- Live clock -->
        <div
          class="d-flex align-items-center gap-2 px-3 py-1 rounded-pill"
          style="background:rgba(111,66,193,.08);border:1px solid rgba(111,66,193,.2);"
        >
          <i class="ri-time-line text-primary" style="font-size:.9rem;"></i>
          <div class="text-center" style="line-height:1.2;">
            <div
              class="fw-bold font-monospace text-primary"
              id="liveClock"
              style="font-size:.95rem;letter-spacing:.05em;"
            >
              --:--:--
            </div>
            <div class="text-muted" id="liveDate" style="font-size:.7rem;">--/--/----</div>
          </div>
        </div>
        <button class="btn btn-sm btn-outline-secondary" id="refreshCaja" title="Actualizar caja">
          <i class="ri-refresh-line"></i>
        </button>
      </div>
    </div>

    <!-- Period selector -->
    <div class="card-body border-bottom py-2">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="btn-group btn-group-sm" role="group" aria-label="Período de caja">
          <button class="btn btn-primary date-preset" data-preset="today">Hoy</button>
          <button class="btn btn-outline-secondary date-preset" data-preset="yesterday">Ayer</button
          >
          <button class="btn btn-outline-secondary date-preset" data-preset="week"
            >Esta semana</button
          >
          <button class="btn btn-outline-secondary date-preset" data-preset="month">Este mes</button
          >
          <button class="btn btn-outline-secondary date-preset" data-preset="all">Todo</button>
          <button class="btn btn-outline-secondary date-preset" data-preset="custom">
            <i class="ri-calendar-line me-1"></i>Personalizado
          </button>
        </div>
        <!-- Custom date range (shown only on "Personalizado") -->
        <div
          class="d-flex align-items-center gap-1"
          id="customRangeWrap"
          style="display:none!important;"
        >
          <input
            type="date"
            id="dateFrom"
            class="form-control form-control-sm"
            style="width:140px;"
            aria-label="Desde"
          />
          <span class="text-muted small">—</span>
          <input
            type="date"
            id="dateTo"
            class="form-control form-control-sm"
            style="width:140px;"
            aria-label="Hasta"
          />
          <button class="btn btn-sm btn-primary" id="applyDateRange" title="Aplicar rango">
            <i class="ri-check-line"></i>
          </button>
        </div>
        <span
          id="dateRangeLabel"
          class="badge bg-primary-subtle text-primary ms-1"
          style="font-size:.8rem;"></span>
      </div>
    </div>

    <!-- Caja metrics -->
    <div class="card-body" id="cajaBody">
      <div class="text-center py-3 text-muted"><i class="ri-loader-4-line ri-spin"></i></div>
    </div>
  </div>

  <!-- ── Sales table ─────────────────────────────────────── -->
  <div class="card">
    <div class="card-body">
      <div class="astero-table">
        <!-- Status Filter Tabs -->
        <nav class="navbar navbar-expand overflow-auto p-0 mb-4" aria-label="Filtros de ventas">
          <div class="navbar-nav gap-3">
            <a
              href="javascript:void(0)"
              class="nav-link fw-medium px-1 hist-filter active border-bottom border-2 border-dark d-flex align-items-start"
              data-filter="all"
              aria-current="page"
            >
              <i class="ri-apps-2-line me-1" aria-hidden="true"></i>Todas
              <span id="hCountAll" class="badge bg-primary-subtle text-primary ms-1">0</span>
            </a>
            <a
              href="javascript:void(0)"
              class="nav-link fw-medium px-1 hist-filter d-flex align-items-start"
              data-filter="activa"
            >
              <i class="ri-check-double-line me-1" aria-hidden="true"></i>Activas
              <span id="hCountActive" class="badge bg-success-subtle text-success ms-1">0</span>
            </a>
            <a
              href="javascript:void(0)"
              class="nav-link fw-medium px-1 hist-filter d-flex align-items-start"
              data-filter="anulada"
            >
              <i class="ri-forbid-line me-1" aria-hidden="true"></i>Anuladas
              <span id="hCountCancelled" class="badge bg-danger-subtle text-danger ms-1">0</span>
            </a>
          </div>
        </nav>

        <!-- Search & Actions -->
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
          <div class="search-wrapper">
            <i class="ri-search-2-line search-icon" aria-hidden="true"></i>
            <input
              type="text"
              id="histSearch"
              class="form-control search-input"
              placeholder="Buscar cliente, vendedor o método..."
              aria-label="Buscar ventas"
            />
            <button
              type="button"
              id="histSearchClear"
              class="btn-clear search-clear"
              style="display:none;"
              aria-label="Limpiar búsqueda"
            >
              <i class="ri-close-line"></i>
            </button>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <!-- Bulk Actions -->
            <div class="bulk-actions-div d-none" id="histBulkActions">
              <span class="selected-count me-2" aria-live="polite"
                ><span id="histSelectedCount">0</span> seleccionados</span
              >
              <button
                class="btn btn-light-danger shadow-none align-items-center gap-2"
                id="histBulkDeleteBtn"
                aria-label="Anular seleccionados"
              >
                <i class="ri-forbid-line me-1" aria-hidden="true"></i> Anular selec.
              </button>
            </div>
          </div>
        </div>

        <!-- Summary stats -->
        <div class="row g-3 text-center mb-4 pb-3 border-bottom">
          <div class="col-6 col-md-3">
            <div class="text-muted small">Total ventas</div>
            <div class="fw-bold fs-5" id="statTotal">—</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Ingresos totales</div>
            <div class="fw-bold fs-5 text-primary" id="statRevenue">—</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Promedio por venta</div>
            <div class="fw-bold fs-5" id="statAvg">—</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="text-muted small">Venta más alta</div>
            <div class="fw-bold fs-5 text-success" id="statMax">—</div>
          </div>
        </div>

        <!-- Table -->
        <div class="table-container">
          <div class="table-responsive border-0">
            <table class="table table-hover table-row-dashed mb-0" aria-label="Historial de ventas">
              <thead>
                <tr>
                  <th class="checkbox-column fs-6" style="width: 20px;" scope="col">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="checkbox"
                        id="histSelectAll"
                        aria-label="Seleccionar todas las ventas"
                      />
                    </div>
                  </th>
                  <th scope="col" data-sortable data-sort-key="fecha"
                    ><i class="ri-calendar-line me-1" aria-hidden="true"></i>FECHA</th
                  >
                  <th scope="col" data-sortable data-sort-key="cliente"
                    ><i class="ri-user-3-line me-1" aria-hidden="true"></i>CLIENTE</th
                  >
                  <th scope="col" data-sortable data-sort-key="vendedor"
                    ><i class="ri-user-star-line me-1" aria-hidden="true"></i>VENDEDOR</th
                  >
                  <th class="text-end" scope="col" data-sortable data-sort-key="total"
                    ><i class="ri-money-dollar-circle-line me-1" aria-hidden="true"></i>TOTAL</th
                  >
                  <th scope="col"><i class="ri-bank-card-line me-1" aria-hidden="true"></i>PAGO</th>
                  <th class="text-center" scope="col" data-sortable data-sort-key="estado"
                    ><i class="ri-flag-2-line me-1" aria-hidden="true"></i>ESTADO</th
                  >
                  <th class="text-end pe-3 no-sort" scope="col"
                    ><i class="ri-settings-3-line me-1" aria-hidden="true"></i>ACCIONES</th
                  >
                </tr>
              </thead>
              <tbody id="histTableBody">
                <tr>
                  <td colspan="8" class="text-center text-muted py-5">
                    <i class="ri-loader-4-line ri-spin"></i> Cargando historial...
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="card-footer border-0 p-0" id="histPgFooter"></div>
  </div>
</AdminLayout>

<script is:inline define:vars={{ receiptLogoUrl }}>
  window.__RECEIPT_LOGO_URL = receiptLogoUrl
</script>
<script>
  import {
    printSaleReceipt,
    buildSaleReceiptHtml,
    downloadReceiptHtml
  } from '../../assets/js/sale-receipt-print.js'
  // @ts-expect-error — API global para el script inline de la página
  window.NoryxPrintSaleReceipt = printSaleReceipt
  // @ts-expect-error
  window.NoryxBuildSaleReceiptHtml = buildSaleReceiptHtml
  // @ts-expect-error
  window.NoryxDownloadReceiptHtml = downloadReceiptHtml
</script>

<!-- Sale detail modal -->
<div class="modal fade" id="saleDetailModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered sale-detail-dialog">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold d-flex align-items-center gap-2">
          <span
            class="d-inline-flex align-items-center justify-content-center rounded-2 bg-primary bg-opacity-10 text-primary"
            style="width:36px;height:36px;"
          >
            <i class="ri-receipt-line"></i>
          </span>
          Detalle de venta
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-2" id="saleDetailBody">
        <div class="text-center py-4 text-muted"><i class="ri-loader-4-line ri-spin"></i></div>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"
          >Cerrar</button
        >
        <button type="button" class="btn btn-sm btn-outline-primary d-none" id="downloadReceiptBtn">
          <i class="ri-download-2-line me-1"></i>Descargar recibo
        </button>
        <button type="button" class="btn btn-sm btn-primary d-none" id="printReceiptBtn">
          <i class="ri-printer-line me-1"></i>Imprimir
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Cancel reason modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2 border-0">
        <h5 class="modal-title text-danger"><i class="ri-forbid-line me-2"></i>Anular venta</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted mb-3">
          Se restaurará el stock de todos los productos. Esta acción no se puede deshacer.
        </p>
        <div class="mb-3">
          <label class="form-label small fw-semibold"
            >Motivo de anulación <span class="text-danger">*</span></label
          >
          <textarea
            class="form-control"
            id="cancelMotivo"
            rows="3"
            placeholder="Ej: Error en precio, devolución del cliente, duplicado..."
            required></textarea>
          <div class="invalid-feedback">El motivo es requerido.</div>
        </div>
        <div class="d-flex justify-content-end gap-2">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal"
            >Cancelar</button
          >
          <button type="button" class="btn btn-danger btn-sm" id="confirmCancelBtn">
            <i class="ri-forbid-line me-1"></i>Anular venta
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
  <div id="histToast" class="toast align-items-center border-0" role="alert" aria-live="assertive">
    <div class="d-flex">
      <div class="toast-body fw-semibold" id="histToastMsg"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
      ></button>
    </div>
  </div>
</div>

<script is:inline>
  ;(function () {
    const API =
      window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
        ? 'http://localhost:4000'
        : ''

    const fmt = (n) => '$' + Number(n || 0).toFixed(2)
    const esc = (s) =>
      String(s ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
    const fmtDate = (v) =>
      v ? new Date(v).toLocaleString('es-MX', { dateStyle: 'short', timeStyle: 'short' }) : '—'

    function formatPagoSearchString(s) {
      const m = s?.pagos_mixtos
      const deuda = Number(s?.saldo_pendiente || 0)
      const debtWords = deuda > 0.01 ? 'deuda saldo pendiente credito' : ''
      if (Array.isArray(m) && m.length) {
        return [
          'mixto',
          ...m.map((p) => `${String(p.metodo || '').toLowerCase()}`),
          debtWords
        ].join(' ')
      }
      return `${String(s?.metodo_pago || '').toLowerCase()} ${debtWords}`.trim()
    }

    function formatPagoDetailHtml(sale) {
      const m = sale?.pagos_mixtos
      const pagado = Number(sale?.total_pagado || 0)
      const saldo = Number(sale?.saldo_pendiente || 0)
      const debtBlock =
        saldo > 0.01
          ? `<div class="small text-warning mt-1">Pagado: ${fmt(pagado)} · Pendiente: ${fmt(saldo)}</div>`
          : ''
      if (Array.isArray(m) && m.length) {
        const lines = m
          .map(
            (p) =>
              `<div class="small text-body-secondary mt-1">${esc(p.metodo || '')}: ${fmt(Number(p.monto))}</div>`
          )
          .join('')
        return `<div><span class="badge text-bg-secondary">Mixto</span>${lines}${debtBlock}</div>`
      }
      return `<div><span class="badge text-bg-secondary">${esc(sale?.metodo_pago || '—')}</span>${debtBlock}</div>`
    }

    // ── State ──────────────────────────────────────────────────
    let allSales = []
    let currentFilter = 'all'
    let currentPage = 1
    let pageSize = 10
    let dateFrom = null
    let dateTo = null
    let activePreset = 'today'
    let pendingCancelId = null
    let sortKey = null
    let sortDir = 'asc'
    let lastReceiptPayload = null

    function bindPrintReceiptOnce() {
      const btn = document.getElementById('printReceiptBtn')
      if (btn && btn.dataset.bound !== '1') {
        btn.dataset.bound = '1'
        btn.addEventListener('click', () => {
          if (!lastReceiptPayload || typeof window.NoryxPrintSaleReceipt !== 'function') return
          window.NoryxPrintSaleReceipt(lastReceiptPayload.sale, lastReceiptPayload.details, {
            logoUrl: window.__RECEIPT_LOGO_URL
          })
        })
      }
      const dl = document.getElementById('downloadReceiptBtn')
      if (dl && dl.dataset.bound !== '1') {
        dl.dataset.bound = '1'
        dl.addEventListener('click', () => {
          if (!lastReceiptPayload || typeof window.NoryxBuildSaleReceiptHtml !== 'function') return
          const html = window.NoryxBuildSaleReceiptHtml(
            lastReceiptPayload.sale,
            lastReceiptPayload.details,
            {
              logoUrl: window.__RECEIPT_LOGO_URL
            }
          )
          const n = lastReceiptPayload.sale?.numero_comprobante
          const base = n != null && Number.isFinite(Number(n)) ? `Recibo-${Number(n)}` : 'Recibo'
          if (typeof window.NoryxDownloadReceiptHtml === 'function') {
            window.NoryxDownloadReceiptHtml(html, base)
          }
        })
      }
    }

    // ── Live clock ─────────────────────────────────────────────
    function tickClock() {
      const now = new Date()
      const clockEl = document.getElementById('liveClock')
      const dateEl = document.getElementById('liveDate')
      if (clockEl)
        clockEl.textContent = now.toLocaleTimeString('es-BO', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit'
        })
      if (dateEl)
        dateEl.textContent = now.toLocaleDateString('es-BO', {
          weekday: 'short',
          day: '2-digit',
          month: 'short',
          year: 'numeric'
        })
    }
    tickClock()
    setInterval(tickClock, 1000)

    // ── Init ───────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
      // Initialize with "today" preset (skipReload=true to avoid double load)
      applyPreset('today', true)
      loadSales()
      loadCaja()
      bindPrintReceiptOnce()

      const searchEl = document.getElementById('histSearch')
      const clearEl = document.getElementById('histSearchClear')
      searchEl.addEventListener('input', () => {
        currentPage = 1
        clearEl.style.display = searchEl.value ? '' : 'none'
        renderTable()
      })
      clearEl.addEventListener('click', () => {
        searchEl.value = ''
        clearEl.style.display = 'none'
        currentPage = 1
        renderTable()
      })

      document.querySelectorAll('.hist-filter').forEach((btn) => {
        btn.addEventListener('click', function () {
          document.querySelectorAll('.hist-filter').forEach((b) => {
            b.classList.remove('active', 'border-bottom', 'border-2', 'border-dark')
          })
          this.classList.add('active', 'border-bottom', 'border-2', 'border-dark')
          currentFilter = this.dataset.filter
          currentPage = 1
          renderTable()
        })
      })

      // Date presets — in caja card, control both caja + table
      document.querySelectorAll('.date-preset').forEach((btn) => {
        btn.addEventListener('click', function () {
          currentPage = 1
          applyPreset(this.dataset.preset)
          // applyPreset calls loadCaja() + renderTable() internally
        })
      })

      // Custom range "Apply" button
      document.getElementById('applyDateRange').addEventListener('click', () => {
        const from = document.getElementById('dateFrom').value
        const to = document.getElementById('dateTo').value
        if (!from || !to) {
          alert('Selecciona ambas fechas')
          return
        }
        dateFrom = new Date(from + 'T00:00:00')
        dateTo = new Date(to + 'T23:59:59')
        const fmtShort = (d) =>
          d.toLocaleDateString('es-BO', { day: '2-digit', month: '2-digit', year: 'numeric' })
        const label = `${fmtShort(dateFrom)} — ${fmtShort(dateTo)}`
        const labelEl = document.getElementById('dateRangeLabel')
        const titleEl = document.getElementById('cajaPeriodTitle')
        if (labelEl) labelEl.textContent = label
        if (titleEl) titleEl.textContent = label
        currentPage = 1
        loadCaja()
        renderTable()
      })

      document.getElementById('refreshCaja').addEventListener('click', loadCaja)
      document.getElementById('confirmCancelBtn').addEventListener('click', doCancel)

      // Select all checkbox
      document.getElementById('histSelectAll').addEventListener('change', function () {
        const checked = this.checked
        document.querySelectorAll('.hist-row-cb').forEach((cb) => {
          cb.checked = checked
        })
        updateHistBulkUI()
      })

      // Sortable headers
      document
        .querySelectorAll('table[aria-label="Historial de ventas"] thead th[data-sortable]')
        .forEach((th) => {
          th.style.cursor = 'pointer'
          th.addEventListener('click', () => {
            const key = th.dataset.sortKey
            if (sortKey === key) {
              sortDir = sortDir === 'asc' ? 'desc' : 'asc'
            } else {
              sortKey = key
              sortDir = 'asc'
            }
            document
              .querySelectorAll('table[aria-label="Historial de ventas"] thead th[data-sortable]')
              .forEach((h) => {
                h.classList.remove('sort-asc', 'sort-desc')
              })
            th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc')
            currentPage = 1
            renderTable()
          })
        })
    })

    // ── Date presets ───────────────────────────────────────────
    function applyPreset(preset, skipReload) {
      activePreset = preset
      document.querySelectorAll('.date-preset').forEach((b) => {
        b.classList.toggle('btn-primary', b.dataset.preset === preset)
        b.classList.toggle('btn-outline-secondary', b.dataset.preset !== preset)
      })

      const customWrap = document.getElementById('customRangeWrap')
      const labelEl = document.getElementById('dateRangeLabel')
      const titleEl = document.getElementById('cajaPeriodTitle')

      const now = new Date()
      const fmtShort = (d) =>
        d.toLocaleDateString('es-BO', { day: '2-digit', month: '2-digit', year: 'numeric' })

      if (preset === 'today') {
        dateFrom = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0)
        dateTo = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59)
        if (labelEl) labelEl.textContent = fmtShort(now)
        if (titleEl) titleEl.textContent = 'Hoy'
        customWrap?.style.setProperty('display', 'none', 'important')
      } else if (preset === 'yesterday') {
        const y = new Date(now)
        y.setDate(y.getDate() - 1)
        dateFrom = new Date(y.getFullYear(), y.getMonth(), y.getDate(), 0, 0, 0)
        dateTo = new Date(y.getFullYear(), y.getMonth(), y.getDate(), 23, 59, 59)
        if (labelEl) labelEl.textContent = fmtShort(y)
        if (titleEl) titleEl.textContent = 'Ayer'
        customWrap?.style.setProperty('display', 'none', 'important')
      } else if (preset === 'week') {
        const dow = now.getDay()
        const monday = new Date(now)
        monday.setDate(now.getDate() - dow + (dow === 0 ? -6 : 1))
        dateFrom = new Date(monday.getFullYear(), monday.getMonth(), monday.getDate(), 0, 0, 0)
        dateTo = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59)
        if (labelEl) labelEl.textContent = `${fmtShort(monday)} — ${fmtShort(now)}`
        if (titleEl) titleEl.textContent = 'Esta semana'
        customWrap?.style.setProperty('display', 'none', 'important')
      } else if (preset === 'month') {
        dateFrom = new Date(now.getFullYear(), now.getMonth(), 1, 0, 0, 0)
        dateTo = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 59, 59)
        if (labelEl)
          labelEl.textContent = now.toLocaleDateString('es-BO', { month: 'long', year: 'numeric' })
        if (titleEl) titleEl.textContent = now.toLocaleDateString('es-BO', { month: 'long' })
        customWrap?.style.setProperty('display', 'none', 'important')
      } else if (preset === 'all') {
        dateFrom = null
        dateTo = null
        if (labelEl) labelEl.textContent = 'Todo el tiempo'
        if (titleEl) titleEl.textContent = 'Todo el tiempo'
        customWrap?.style.setProperty('display', 'none', 'important')
      } else if (preset === 'custom') {
        // Don't reset dates — let user pick via inputs
        if (labelEl) labelEl.textContent = ''
        if (titleEl) titleEl.textContent = 'Personalizado'
        customWrap?.style.removeProperty('display')
        return // Don't auto-reload — wait for "Aplicar"
      }

      if (!skipReload) {
        loadCaja()
        renderTable()
      }
    }

    // ── Load data ──────────────────────────────────────────────
    async function loadSales() {
      try {
        const res = await fetch(API + '/api/sales')
        allSales = await res.json()
        updateCounts()
        renderTable()
      } catch {
        document.getElementById('histTableBody').innerHTML =
          '<tr><td colspan="7" class="text-center text-danger py-4">Error al cargar el historial</td></tr>'
      }
    }

    // ── Caja del período ───────────────────────────────────────
    async function loadCaja() {
      const body = document.getElementById('cajaBody')
      body.innerHTML =
        '<div class="text-center py-3 text-muted"><i class="ri-loader-4-line ri-spin"></i></div>'
      try {
        const params = new URLSearchParams()
        if (activePreset === 'all') {
          params.set('period', 'all')
        } else if (dateFrom && dateTo) {
          params.set('from', dateFrom.toISOString())
          params.set('to', dateTo.toISOString())
          const labelEl = document.getElementById('dateRangeLabel')
          if (labelEl?.textContent) params.set('label', labelEl.textContent)
        }
        // no params = server defaults to today

        const res = await fetch(API + '/api/summary/caja?' + params.toString())
        const data = await res.json()

        const periodLabel = document.getElementById('cajaPeriodTitle')?.textContent || 'el período'

        const paymentColors = {
          Efectivo: {
            bg: 'rgba(25,135,84,.12)',
            color: '#198754',
            icon: 'ri-money-dollar-circle-line'
          },
          QR: { bg: 'rgba(13,202,240,.12)', color: '#0dcaf0', icon: 'ri-qr-code-line' },
          Mixto: { bg: 'rgba(253,126,20,.12)', color: '#fd7e14', icon: 'ri-exchange-funds-line' }
        }
        const defaultStyle = {
          bg: 'rgba(111,66,193,.12)',
          color: '#6f42c1',
          icon: 'ri-bank-card-line'
        }

        const payCards = data.byPayment.length
          ? data.byPayment
              .map((p) => {
                const method = p._id || 'Sin método'
                const style = paymentColors[method] || defaultStyle
                return `
              <div class="col-6 col-md-3">
                <div class="caja-card p-3 h-100">
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="caja-icon" style="background:${style.bg};color:${style.color};">
                      <i class="${style.icon}"></i>
                    </div>
                    <div class="fw-semibold small">${esc(method)}</div>
                  </div>
                  <div class="fw-bold fs-5" style="color:${style.color};">${fmt(p.total)}</div>
                  <div class="text-muted" style="font-size:.75rem;">${p.count} venta${p.count !== 1 ? 's' : ''}</div>
                </div>
              </div>`
              })
              .join('')
          : `<div class="col-12 col-md-6">
             <div class="caja-card p-3 text-center text-muted">
               <i class="ri-inbox-line d-block mb-1" style="font-size:1.5rem;"></i>
               <small>Sin ventas en este período</small>
             </div>
           </div>`

        body.innerHTML = `
        <div class="row g-3 mb-3">
          <div class="col-6 col-md-3">
            <div class="caja-card p-3 h-100">
              <div class="d-flex align-items-center gap-2 mb-2">
                <div class="caja-icon" style="background:rgba(111,66,193,.12);color:#6f42c1;"><i class="ri-shopping-bag-3-line"></i></div>
                <div class="fw-semibold small">Ventas activas</div>
              </div>
              <div class="fw-bold fs-5 text-primary">${data.totalVentas}</div>
              <div class="text-muted" style="font-size:.75rem;">${data.annulled} anulada${data.annulled !== 1 ? 's' : ''} en el período</div>
            </div>
          </div>
          <div class="col-6 col-md-3">
            <div class="caja-card p-3 h-100">
              <div class="d-flex align-items-center gap-2 mb-2">
                <div class="caja-icon" style="background:rgba(25,135,84,.12);color:#198754;"><i class="ri-money-cny-circle-line"></i></div>
                <div class="fw-semibold small">Ingresos del período</div>
              </div>
              <div class="fw-bold fs-5 text-success">${fmt(data.totalIngresos)}</div>
              <div class="text-muted" style="font-size:.75rem;">solo ventas activas</div>
            </div>
          </div>
          ${payCards}
        </div>
        <div class="text-muted" style="font-size:.72rem;">
          <i class="ri-time-line me-1"></i>${esc(data.date)} · Solo ventas activas
        </div>`
      } catch {
        body.innerHTML =
          '<div class="text-danger small text-center py-3"><i class="ri-error-warning-line me-1"></i>No se pudo cargar la caja</div>'
      }
