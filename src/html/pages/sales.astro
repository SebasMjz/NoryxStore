    // ── Cancel with reason ─────────────────────────────────────
    function openCancelModal(saleId) {
      pendingCancelId = saleId
      document.getElementById('cancelMotivo').value = ''
      document.getElementById('cancelMotivo').classList.remove('is-invalid')
      new bootstrap.Modal(document.getElementById('cancelModal')).show()
    }

    async function doCancel() {
      if (!pendingCancelId) return
      const motivo = document.getElementById('cancelMotivo').value.trim()
      if (!motivo) {
        document.getElementById('cancelMotivo').classList.add('is-invalid')
        return
      }
      const btn = document.getElementById('confirmCancelBtn')
      btn.disabled = true
      btn.innerHTML = '<i class="ri-loader-4-line ri-spin me-1"></i>Anulando...'
      const user = window.__authUser || {}
      try {
        const res = await fetch(`${API}/api/sales/${pendingCancelId}/cancel`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'x-user-id': user.id || '',
            'x-user-name': user.nombre || ''
          },
          body: JSON.stringify({ motivo })
        })
        if (!res.ok) throw new Error()
        bootstrap.Modal.getInstance(document.getElementById('cancelModal')).hide()
        showToast('Venta anulada. Stock restaurado.', 'warning')
        await loadSales()
        loadCaja()
      } catch {
        showToast('Error al anular la venta', 'danger')
      } finally {
        btn.disabled = false
        btn.innerHTML = '<i class="ri-forbid-line me-1"></i>Anular venta'
      }
    }

    function showToast(msg, type = 'success') {
      const el = document.getElementById('histToast')
      document.getElementById('histToastMsg').textContent = msg
      el.className = `toast align-items-center border-0 text-bg-${type}`
      new bootstrap.Toast(el, { delay: 3000 }).show()
    }
  })()
</script>
